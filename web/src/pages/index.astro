<style>
/* ═══════ NAV ═══════ */
nav {
  position: fixed;
  inset: 0 0 auto 0;
  z-index: var(--z-sticky);
  background: transparent;
  transition: background 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out);
}
nav.scrolled {
  background: oklch(1.000 0.000 0 / 0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  box-shadow: 0 1px 0 var(--line);
}
.nav-inner {
  max-width: var(--maxw);
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72px;
  padding-inline: var(--space-lg);
}
.nav-logo {
  display: flex;
  align-items: center;
  gap: 8px;
  font-weight: 800;
  font-size: 1.15rem;
  letter-spacing: -0.02em;
  color: white;
  transition: color 0.3s;
}
nav.scrolled .nav-logo { color: var(--ink); }
.nav-logo-icon {
  width: 24px;
  height: 24px;
  color: var(--primary-soft);
  transition: color 0.3s;
}
nav.scrolled .nav-logo-icon { color: var(--primary); }
.nav-links {
  display: flex;
  align-items: center;
  gap: 28px;
}
.nav-links a:not(.nav-cta) {
  font-size: var(--text-sm);
  font-weight: 600;
  color: white;
  opacity: 0.9;
  transition: opacity 0.2s, color 0.3s;
}
nav.scrolled .nav-links a:not(.nav-cta) {
  color: var(--muted);
  opacity: 1;
}
.nav-links a:not(.nav-cta):hover { opacity: 1; }
nav.scrolled .nav-links a:not(.nav-cta):hover { color: var(--ink); }
.nav-cta {
  padding: 10px 20px;
  font-size: var(--text-sm);
}
.nav-hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  cursor: pointer;
  padding: 8px;
}
.nav-hamburger span {
  width: 22px;
  height: 2px;
  background: white;
  border-radius: 2px;
  transition: background 0.3s, transform 0.3s;
}
nav.scrolled .nav-hamburger span { background: var(--ink); }

/* ═══════ MOBILE MENU ═══════ */
.mobile-menu {
  position: fixed;
  inset: 72px 0 0 0;
  z-index: calc(var(--z-sticky) - 1);
  background: var(--bg);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: var(--space-xl) var(--space-lg);
  transform: translateY(-100%);
  opacity: 0;
  pointer-events: none;
  transition: transform 0.4s var(--ease-out), opacity 0.3s;
}
.mobile-menu.open {
  transform: translateY(0);
  opacity: 1;
  pointer-events: auto;
}
.mobile-menu-link {
  font-size: var(--text-lg);
  font-weight: 600;
  padding: 12px 0;
  color: var(--ink);
}
.mobile-menu-cta { margin-top: var(--space-md); width: 100%; text-align: center; }

/* ═══════ HERO ═══════ */
#hero {
  position: relative;
  min-height: 100vh;
  min-height: 100dvh;
  display: flex;
  align-items: flex-end;
  padding: 0 0 var(--space-hero);
  overflow: hidden;
}
.hero-bg {
  position: absolute;
  inset: 0;
}
.hero-photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transform: scale(1.05);
  transition: transform 12s var(--ease-out);
}
.hero-photo.loaded { transform: scale(1); }
.hero-overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, oklch(0.12 0.01 55 / 0.45) 0%, oklch(0.12 0.01 55 / 0.08) 30%, transparent 55%, oklch(0.12 0.01 55 / 0.25) 80%, oklch(0.12 0.01 55 / 0.50) 100%),
    linear-gradient(90deg, oklch(0.12 0.01 55 / 0.55) 0%, oklch(0.12 0.01 55 / 0.15) 50%, transparent 100%);
}
.hero-fade {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  height: 14%;
  background: linear-gradient(180deg, transparent 0%, oklch(1.000 0.000 0 / 0.6) 60%, var(--bg) 100%);
  z-index: 1;
  pointer-events: none;
}
.hero-content {
  position: relative;
  z-index: var(--z-raised);
  color: white;
  max-width: 700px;
}
.hero-place {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-weight: 600;
  font-size: var(--text-sm);
  letter-spacing: 0.04em;
  margin-bottom: var(--space-md);
  text-shadow: 0 1px 6px oklch(0.1 0.02 55 / 0.7);
}
.hero-place svg { color: var(--primary-soft); }
#hero h1 {
  color: white;
  font-size: var(--text-hero);
  font-weight: 800;
  line-height: 1.0;
  letter-spacing: -0.03em;
  margin-bottom: var(--space-lg);
  text-shadow: 0 2px 8px oklch(0.1 0.02 55 / 0.5), 0 6px 24px oklch(0.1 0.02 55 / 0.4);
}
.hero-accent {
  color: oklch(0.85 0.10 55);
}
.hero-sub {
  font-size: var(--text-lg);
  font-weight: 500;
  color: oklch(0.92 0.01 55);
  max-width: 540px;
  margin-bottom: var(--space-xl);
  text-shadow: 0 1px 4px oklch(0.1 0.02 55 / 0.6);
}
.hero-btns {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}
.hero-btn-outline {
  background: oklch(1 0 0 / 0.12);
  box-shadow: inset 0 0 0 2px oklch(1 0 0 / 0.45);
  color: white;
}
.hero-btn-outline:hover {
  background: oklch(1 0 0 / 0.25);
  box-shadow: inset 0 0 0 2px oklch(1 0 0 / 0.7);
  color: white;
}
.hero-scroll {
  position: absolute;
  bottom: var(--space-lg);
  left: 50%;
  transform: translateX(-50%);
  z-index: var(--z-raised);
  color: oklch(0.2 0.01 55 / 0.5);
  animation: nudge 2.4s var(--ease-out) infinite;
}
@keyframes nudge {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(8px); }
}

/* ═══════ SECTION HEADERS ═══════ */
.section-header {
  max-width: 640px;
  margin-bottom: var(--space-xl);
}
.section-header h2 {
  font-size: var(--text-3xl);
  margin-bottom: var(--space-sm);
}
.section-sub {
  color: var(--muted);
  font-size: var(--text-lg);
}
.bg-surface { background: var(--surface); }
.bg-dark {
  background: var(--dark-bg);
  color: var(--dark-text);
}
.bg-dark h2 { color: white; }
.bg-dark .section-sub { color: var(--dark-muted); }

/* ═══════ PROBLEM ═══════ */
.problem-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-2xl);
  align-items: start;
}
.problem-left h2 {
  font-size: var(--text-3xl);
  line-height: 1.15;
}
.text-accent { color: var(--primary); }
.text-accent-light { color: oklch(0.78 0.10 55); }
.problem-list {
  list-style: none;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}
.problem-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--muted);
  background: var(--surface);
  border-radius: var(--r-sm);
  border: 1px solid var(--line);
  transition-delay: calc(var(--i, 0) * 40ms);
}
.problem-item svg { color: var(--primary); flex-shrink: 0; }
.problem-answer {
  margin-top: var(--space-lg);
  padding: var(--space-lg);
  background: var(--primary-soft);
  border-radius: var(--r);
  position: relative;
}
.problem-answer-line {
  position: absolute;
  top: -var(--space-lg);
  left: 50%;
  width: 2px;
  height: var(--space-lg);
  background: var(--primary);
}
.problem-answer-text {
  font-size: var(--text-base);
  color: var(--ink);
}
.problem-answer-text strong { color: var(--primary-hover); }

/* ═══════ PROGRAMS ═══════ */
.programs-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-md);
}
.program-card {
  background: var(--bg);
  border: 1px solid var(--line);
  border-radius: var(--r-lg);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transition: transform 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out);
  position: relative;
  transition-delay: calc(var(--i, 0) * 80ms);
}
.program-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}
.program-img-wrapper {
  position: relative;
  width: 100%;
  height: 200px;
  overflow: hidden;
}
.program-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s var(--ease-out);
}
.program-card:hover .program-img {
  transform: scale(1.05);
}
.program-card-body {
  padding: var(--space-lg);
  display: flex;
  flex-direction: column;
  flex: 1;
}
.program-featured {
  border-color: var(--primary);
  box-shadow: var(--shadow);
}
.program-badge {
  position: absolute;
  top: -12px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--primary);
  color: var(--on-primary);
  font-size: var(--text-xs);
  font-weight: 700;
  padding: 6px 16px;
  border-radius: var(--r-pill);
  white-space: nowrap;
}
.program-header { margin-bottom: var(--space-md); }
.program-name {
  font-size: var(--text-xl);
  margin-bottom: 4px;
}
.program-tagline {
  color: var(--muted);
  font-size: var(--text-sm);
}
.program-price {
  margin-bottom: var(--space-md);
  padding-bottom: var(--space-md);
  border-bottom: 1px solid var(--line);
}
.program-price-amount {
  font-size: var(--text-2xl);
  font-weight: 800;
  color: var(--primary);
}
.program-price-note {
  font-size: var(--text-sm);
  color: var(--muted);
  margin-left: 4px;
}
.program-meta {
  display: flex;
  gap: var(--space-md);
  margin-bottom: var(--space-md);
}
.program-meta-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--muted);
}
.program-meta-item svg { color: var(--accent); }
.program-highlights {
  list-style: none;
  flex: 1;
  margin-bottom: var(--space-lg);
}
.program-highlights li {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 0;
  font-size: var(--text-sm);
  color: var(--ink);
}
.program-highlights svg { color: var(--accent); flex-shrink: 0; }
.program-cta { width: 100%; text-align: center; }

/* ═══════ TIMELINE ═══════ */
.timeline {
  position: relative;
  max-width: 700px;
  margin: 0 auto;
  padding-left: 60px;
}
.timeline-line {
  position: absolute;
  left: 24px;
  top: 0;
  bottom: 0;
  width: 2px;
  background: var(--line);
}
.timeline-item {
  position: relative;
  padding-bottom: var(--space-lg);
  transition-delay: calc(var(--i, 0) * 60ms);
}
.timeline-marker {
  position: absolute;
  left: -60px;
  top: 2px;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 48px;
}
.timeline-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--primary);
  box-shadow: 0 0 0 4px var(--primary-soft);
  z-index: var(--z-raised);
}
.timeline-time {
  font-size: var(--text-xs);
  font-weight: 700;
  color: var(--primary);
  margin-top: 6px;
  font-variant-numeric: tabular-nums;
}
.timeline-content {
  padding-left: var(--space-md);
}
.timeline-title {
  font-size: var(--text-lg);
  font-weight: 700;
  margin-bottom: 4px;
}
.timeline-desc {
  font-size: var(--text-sm);
  color: var(--muted);
  line-height: 1.6;
}
.timeline-img-wrapper {
  margin-top: var(--space-sm);
  border-radius: var(--r);
  overflow: hidden;
  aspect-ratio: 16 / 9;
  max-width: 480px;
  border: 1px solid var(--line);
  box-shadow: var(--shadow-sm);
}
.timeline-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.timeline-cta {
  text-align: center;
  margin-top: var(--space-xl);
  padding-top: var(--space-xl);
  border-top: 1px solid var(--line);
}
.timeline-cta p {
  margin: 0 auto var(--space-md);
  color: var(--muted);
  max-width: 50ch;
}
.timeline-cta strong { color: var(--ink); }

/* ═══════ INCLUDES ═══════ */
.includes-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: var(--space-md);
}
.include-item {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: var(--space-lg);
  background: var(--bg);
  border-radius: var(--r);
  border: 1px solid var(--line);
  transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
  transition-delay: calc(var(--i, 0) * 50ms);
}
.include-item:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-sm);
}
.include-icon {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--r-sm);
  background: var(--primary-soft);
  color: var(--primary);
}
.include-icon svg { width: 22px; height: 22px; }
.include-title {
  font-size: var(--text-base);
  font-weight: 700;
}
.include-desc {
  font-size: var(--text-sm);
  color: var(--muted);
  line-height: 1.5;
}

/* ═══════ TRAVEL BOOK ═══════ */
.travelbook-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-2xl);
  align-items: center;
}
.travelbook-text h2 { color: white; font-size: var(--text-3xl); margin-bottom: var(--space-md); }
.travelbook-sub {
  color: var(--dark-muted);
  font-size: var(--text-lg);
  margin-bottom: var(--space-lg);
}
.travelbook-list {
  list-style: none;
  margin-bottom: var(--space-xl);
}
.travelbook-list li {
  padding: 8px 0;
  font-size: var(--text-base);
  color: var(--dark-text);
  display: flex;
  align-items: center;
  gap: 10px;
}
.travelbook-list li::before {
  content: '✓';
  color: var(--primary);
  font-weight: 700;
  flex-shrink: 0;
}
.travelbook-mockup {
  background: oklch(0.22 0.015 55);
  border-radius: var(--r-lg);
  overflow: hidden;
  box-shadow: var(--shadow-lg);
}
.travelbook-mockup-header {
  display: flex;
  gap: 6px;
  padding: 12px 16px;
  background: oklch(0.18 0.012 55);
}
.travelbook-mockup-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: oklch(0.35 0.01 55);
}
.travelbook-mockup-content {
  padding: 20px;
}
.travelbook-mockup-title {
  font-weight: 700;
  font-size: var(--text-base);
  color: white;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid oklch(0.30 0.01 55);
}
.travelbook-mockup-row {
  display: flex;
  gap: 16px;
  padding: 8px 12px;
  border-radius: 6px;
  margin-bottom: 4px;
}
.travelbook-mockup-row.highlighted {
  background: oklch(0.540 0.130 55 / 0.15);
}
.travelbook-mockup-time {
  font-size: var(--text-sm);
  font-weight: 700;
  color: var(--primary);
  font-variant-numeric: tabular-nums;
  width: 48px;
  flex-shrink: 0;
}
.travelbook-mockup-event {
  font-size: var(--text-sm);
