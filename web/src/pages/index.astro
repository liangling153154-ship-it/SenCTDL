---
import Base from '../layouts/Base.astro';

const ZALO_LINK = 'https://zalo.me/0123456789';

const programs = [
  {
    id: '2n1d',
    name: '2 Ngày 1 Đêm',
    tagline: 'Trải nghiệm nhanh, đủ tinh hoa',
    price: '1.890.000đ',
    priceNote: '/người',
    highlights: ['Thác Bản Giốc', 'Động Ngườm Ngao', 'Mắt Thần núi', 'Homestay bản địa'],
    days: 2,
    spots: 6,
    image: 'images/places/ban-gioc.jpg',
  },
  {
    id: '3n2d',
    name: '3 Ngày 2 Đêm',
    tagline: 'Được yêu thích nhất — đủ sâu, đủ chậm',
    price: '2.690.000đ',
    priceNote: '/người',
    highlights: ['Thác Bản Giốc', 'Động Ngườm Ngao', 'Hồ Thang Hen', 'Làng đá Khuổi Ky', 'Chợ phiên địa phương', 'Xe máy khám phá'],
    days: 3,
    spots: 10,
    featured: true,
    image: 'images/places/eye-mountain.jpg',
  },
  {
    id: '4n3d',
    name: '4 Ngày 3 Đêm',
    tagline: 'Khám phá sâu — đi chậm, thấy nhiều',
    price: '3.490.000đ',
    priceNote: '/người',
    highlights: ['Tất cả điểm 3N2Đ', 'Pác Bó', 'Phja Oắc', 'Cốc Bó suối Lê-nin', 'Đèo Mã Phục', 'Cafe núi'],
    days: 4,
    spots: 14,
    image: 'images/places/khau-coc-cha.jpg',
  },
];



const includes = [
  { icon: 'bus', title: 'Vé xe khách', desc: 'Limousine Hà Nội — Cao Bằng khứ hồi' },
  { icon: 'bike', title: 'Xe máy', desc: 'Honda Wave/Winner X, đầy xăng, áo mưa' },
  { icon: 'home', title: 'Homestay', desc: 'Phòng riêng, sàn gỗ, chăn ấm, wifi' },
  { icon: 'utensils', title: 'Ăn sáng', desc: 'Mỗi sáng tại quán được chọn' },
  { icon: 'map', title: 'Lịch trình tối ưu', desc: 'Travel Book chi tiết từng giờ' },
  { icon: 'phone', title: 'Hotline 24/7', desc: 'Hỗ trợ suốt chuyến đi' },
  { icon: 'shield', title: 'Phương án dự phòng', desc: 'Kế hoạch B khi trời mưa' },
  { icon: 'gift', title: 'Bonus', desc: 'Bản đồ offline, gợi ý quán ăn, góc chụp đẹp' },
];

const faqs = [
  { q: 'Giá đã bao gồm những gì?', a: 'Vé xe khách khứ hồi, homestay, xe máy, ăn sáng, Travel Book, và hotline hỗ trợ 24/7. Bữa trưa và tối tự chọn — Travel Book gợi ý quán cụ thể với giá tham khảo.' },
  { q: 'Tôi có thể đi một mình không?', a: 'Hoàn toàn được. Phần lớn khách của chúng tôi đi một mình hoặc theo cặp. Lịch trình được thiết kế cho cả người đi solo.' },
  { q: 'Tôi không biết đi xe máy thì sao?', a: 'Có thể chọn option Easy Rider — tài xế địa phương chở bạn. Hoặc chọn chương trình ô tô (sắp ra mắt).' },
  { q: 'Nếu trời mưa thì sao?', a: 'Travel Book có phương án dự phòng cho mỗi hoạt động. Ví dụ: trời mưa ở Bản Giốc → chuyển thời gian xuống chiều, sáng ghé chợ phiên hoặc làng nghề thay thế.' },
  { q: 'Có thể thay đổi lịch trình không?', a: 'Có. Travel Book là gợi ý tối ưu, không phải bắt buộc. Bạn tự do điều chỉnh — hotline luôn sẵn sàng hỗ trợ.' },
  { q: 'Thanh toán như thế nào?', a: 'Chuyển khoản ngân hàng hoặc MoMo. Đặt cọc 50%, thanh toán nốt trước ngày khởi hành 3 ngày.' },
  { q: 'Hủy thì sao?', a: 'Hủy trước 7 ngày: hoàn 100%. Trước 3 ngày: hoàn 70%. Dưới 3 ngày: không hoàn. Chúng tôi cần confirm với đối tác.' },
];

const gallery = [
  { src: 'images/gallery-01.jpg', alt: 'Cảnh quan thác Bản Giốc hùng vĩ vùng biên giới' },
  { src: 'images/gallery-02.jpg', alt: 'Ruộng bậc thang uốn lượn chín vàng' },
  { src: 'images/gallery-03.jpg', alt: 'Đèo Khâu Cốc Chà 15 tầng dốc uốn khúc' },
  { src: 'images/gallery-04.jpg', alt: 'Dòng sông Quây Sơn trong xanh chảy dọc biên cương' },
  { src: 'images/gallery-05.JPG', alt: 'Làng đá cổ Khuổi Ky của người Tày' },
  { src: 'images/gallery-06.JPG', alt: 'Hồ Thang Hen xanh ngọc bích phẳng lặng giữa lòng thung lũng' },
];

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<Base
  title="Chương trình Du lịch Cao Bằng — Chuyến đi đã được thiết kế"
  description="Không cần lên kế hoạch. Không cần lo lắng. Chọn chương trình, nhắn Zalo — chúng tôi lo mọi thứ từ xe, phòng, lịch trình đến quán ăn."
>

<!-- ═══════ NAV ═══════ -->
<nav id="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Về trang chủ">
      <svg class="nav-logo-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M12 6v6l4 2"/></svg>
      <span>Cao Bằng Travel</span>
    </a>
    <div class="nav-links" id="navLinks">
      <a href="#programs">Chương trình</a>
      <a href="#includes">Bao gồm</a>
      <a href="#faq">FAQ</a>
      <a href={ZALO_LINK} class="btn btn-zalo nav-cta" target="_blank" rel="noopener">
        <svg class="btn-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12.49 10.272v-.45h1.347v6.322h-.527a.825.825 0 0 1-.82-.826v-.005a3.076 3.076 0 0 1-1.81.582c-1.7 0-3.076-1.418-3.076-3.166s1.376-3.162 3.076-3.162a3.08 3.08 0 0 1 1.81.582v.123zm-1.667 4.727a1.975 1.975 0 0 0 0-3.95 1.975 1.975 0 0 0 0 3.95zM17.56 9.822h1.347v5.571a.825.825 0 0 1-.82.826h-.527V9.822zM18.234 7.5a.875.875 0 1 1 0 1.75.875.875 0 0 1 0-1.75z"/><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm-4.438 12.958a.655.655 0 0 1-.19.014H5.654v-5.15h1.347v3.884h1.42l.015.015c.15.004.518.064.518.518v.184a.55.55 0 0 1-.394.535zm1.027-5.136a.875.875 0 1 1 0-1.75.875.875 0 0 1 0 1.75z"/></svg>
        Nhắn Zalo
      </a>
    </div>
    <button class="nav-hamburger" id="navToggle" aria-label="Mở menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- ═══════ MOBILE MENU ═══════ -->
<div class="mobile-menu" id="mobileMenu" aria-hidden="true">
  <a href="#programs" class="mobile-menu-link">Chương trình</a>
  <a href="#includes" class="mobile-menu-link">Bao gồm</a>
  <a href="#faq" class="mobile-menu-link">FAQ</a>
  <a href={ZALO_LINK} class="btn btn-zalo mobile-menu-cta" target="_blank" rel="noopener">
    Nhắn Zalo ngay
  </a>
</div>

<!-- ═══════ HERO ═══════ -->
<section id="hero">
  <div class="hero-bg">
    <img
      src="images/hero/hero-main.jpg"
      alt="Cảnh núi đá vôi và ruộng bậc thang ở Cao Bằng, Việt Nam"
      class="hero-photo"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-overlay"></div>
    <div class="hero-fade"></div>
  </div>
  <div class="wrap hero-content">
    <p class="hero-place reveal">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      Cao Bằng, Việt Nam
    </p>
    <h1 class="reveal reveal-delay-1">
      Chuyến đi đã được<br/>
      <span class="hero-accent">thiết kế cho bạn.</span>
    </h1>
    <p class="hero-sub reveal reveal-delay-2">
      Không cần lên kế hoạch. Không cần lo lắng. Chọn chương trình — chúng tôi lo mọi thứ từ xe, phòng, lịch trình đến quán ăn.
    </p>
    <div class="hero-btns reveal reveal-delay-3">
      <a href={ZALO_LINK} class="btn btn-primary" target="_blank" rel="noopener">
        Nhắn Zalo — Đặt chương trình
      </a>
      <a href="#programs" class="btn btn-outline hero-btn-outline">
        Xem chương trình
      </a>
    </div>
  </div>
  <div class="hero-scroll" aria-hidden="true">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
  </div>
</section>

<!-- ═══════ PROBLEM ═══════ -->
<section id="problem" class="section-pad">
  <div class="wrap">
    <div class="problem-layout">
      <div class="problem-left reveal">
        <h2>Tự đi Cao Bằng?<br/>Bạn phải quyết định<br/><span class="text-accent">15 thứ.</span></h2>
      </div>
      <div class="problem-right">
        <ul class="problem-list">
          {['Đi xe nào?', 'Mấy giờ xuất phát?', 'Thuê xe ở đâu?', 'Đi điểm nào trước?', 'Có kịp không?', 'Ăn sáng ở đâu?', 'Ăn trưa ở đâu?', 'Cafe ở đâu?', 'Đường nào đẹp?', 'Mấy giờ check-in?', 'Cần đặt vé trước?', 'Điểm nào đáng đi?'].map((item, i) => (
            <li class="problem-item reveal" style={`--i: ${i}`}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
              {item}
            </li>
          ))}
        </ul>
        <div class="problem-answer reveal">
          <div class="problem-answer-line"></div>
          <p class="problem-answer-text">
            <strong>Chúng tôi đã giải quyết tất cả.</strong><br/>
            Bạn chỉ cần chọn chương trình. Mọi thứ còn lại đã được chuẩn bị.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════ PROGRAMS ═══════ -->
<section id="programs" class="section-pad bg-surface">
  <div class="wrap">
    <div class="section-header reveal">
      <h2>Chọn chương trình<br/>phù hợp với bạn</h2>
      <p class="section-sub">Mỗi chương trình là một chuyến đi hoàn chỉnh — từ xe, phòng, lịch trình đến quán ăn. Bạn chỉ cần xách balo lên.</p>
    </div>
    <div class="programs-grid">
      {programs.map((p, i) => (
        <div class={`program-card reveal ${p.featured ? 'program-featured' : ''}`} style={`--i: ${i}`}>
          {p.featured && <div class="program-badge">Được chọn nhiều nhất</div>}
          <div class="program-img-wrapper">
            <img src={p.image} alt={p.name} class="program-img" loading="lazy" />
          </div>
          <div class="program-card-body">
            <div class="program-header">
              <h3 class="program-name">{p.name}</h3>
              <p class="program-tagline">{p.tagline}</p>
            </div>
            <div class="program-price">
              <span class="program-price-amount">{p.price}</span>
              <span class="program-price-note">{p.priceNote}</span>
            </div>
            <div class="program-meta">
              <span class="program-meta-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                {p.days} ngày
              </span>
              <span class="program-meta-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {p.spots} điểm đến
              </span>
            </div>
            <ul class="program-highlights">
              {p.highlights.map(h => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                  {h}
                </li>
              ))}
            </ul>
            <a href={`${base}programs/${p.id}/`} class={`btn ${p.featured ? 'btn-primary' : 'btn-outline'} program-cta`}>
              Xem chi tiết lịch trình
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════ INCLUDES ═══════ -->
<section id="includes" class="section-pad bg-surface">
  <div class="wrap">
    <div class="section-header reveal">
      <h2>Đã bao gồm<br/>trong chương trình</h2>
      <p class="section-sub">Bạn không cần tự đặt từng thứ. Chúng tôi đã chuẩn bị sẵn.</p>
    </div>
    <div class="includes-grid">
      {includes.map((item, i) => (
        <div class="include-item reveal" style={`--i: ${i}`}>
          <div class="include-icon">
            {item.icon === 'bus' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 6v6M16 6v6M2 12h20M6 18h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2zM6 18v2M18 18v2"/></svg>}
            {item.icon === 'bike' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18.5" cy="17.5" r="3.5"/><circle cx="5.5" cy="17.5" r="3.5"/><path d="M15 6a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm-3 11.5V14l-3-3 4-3 2 3h2"/></svg>}
            {item.icon === 'home' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>}
            {item.icon === 'utensils' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2M7 2v20M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/></svg>}
            {item.icon === 'map' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>}
            {item.icon === 'phone' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>}
            {item.icon === 'shield' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
            {item.icon === 'gift' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>}
          </div>
          <h3 class="include-title">{item.title}</h3>
          <p class="include-desc">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════ TRAVEL BOOK ═══════ -->
<section id="travelbook" class="section-pad bg-dark">
  <div class="wrap">
    <div class="travelbook-layout">
      <div class="travelbook-text reveal">
        <h2>Sau khi đặt, bạn nhận<br/><span class="text-accent-light">Travel Book.</span></h2>
        <p class="travelbook-sub">Một kịch bản chi tiết cho chuyến đi — thiết kế riêng cho lịch trình của bạn.</p>
        <ul class="travelbook-list">
          <li>Timeline từng giờ, từng hoạt động</li>
          <li>Google Maps với tất cả điểm đến</li>
          <li>Gợi ý quán ăn, cafe, góc chụp đẹp</li>
          <li>Checklist đồ cần mang</li>
          <li>Phương án dự phòng khi trời mưa</li>
          <li>Hotline hỗ trợ trong chuyến đi</li>
        </ul>
        <a href={ZALO_LINK} class="btn btn-primary" target="_blank" rel="noopener">Nhận Travel Book — Nhắn Zalo</a>
      </div>
      <div class="travelbook-visual reveal reveal-delay-1">
        <div class="travelbook-mockup">
          <div class="travelbook-mockup-header">
            <div class="travelbook-mockup-dot"></div>
            <div class="travelbook-mockup-dot"></div>
            <div class="travelbook-mockup-dot"></div>
          </div>
          <div class="travelbook-mockup-content">
            <div class="travelbook-mockup-title">Travel Book — 3N2Đ</div>
            <div class="travelbook-mockup-row">
              <span class="travelbook-mockup-time">06:00</span>
              <span class="travelbook-mockup-event">Đến Cao Bằng</span>
            </div>
            <div class="travelbook-mockup-row">
              <span class="travelbook-mockup-time">06:30</span>
              <span class="travelbook-mockup-event">Ăn sáng — Phở vịt quay</span>
            </div>
            <div class="travelbook-mockup-row">
              <span class="travelbook-mockup-time">07:15</span>
              <span class="travelbook-mockup-event">Nhận xe máy</span>
            </div>
            <div class="travelbook-mockup-row highlighted">
              <span class="travelbook-mockup-time">09:30</span>
              <span class="travelbook-mockup-event">📍 Thác Bản Giốc</span>
            </div>
            <div class="travelbook-mockup-note">
              ☀️ Góc chụp đẹp nhất lúc sáng sớm, ít khách
            </div>
            <div class="travelbook-mockup-row">
              <span class="travelbook-mockup-time">11:00</span>
              <span class="travelbook-mockup-event">Động Ngườm Ngao</span>
            </div>
            <div class="travelbook-mockup-more">+ 24 hoạt động nữa...</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════ GALLERY ═══════ -->
<section id="gallery" class="section-pad">
  <div class="wrap">
    <div class="section-header reveal">
      <h2>Góc nhìn Cao Bằng</h2>
      <p class="section-sub">Những hình ảnh chân thực được ghi lại từ các chuyến đi của chúng tôi. Cao Bằng đẹp hoang sơ, hùng vĩ và bình dị.</p>
    </div>
    <div class="gallery-grid">
      {gallery.map((item, i) => (
        <div class="gallery-item reveal" style={`--i: ${i}`}>
          <img src={item.src} alt={item.alt} class="gallery-img" loading="lazy" />
          <div class="gallery-caption">
            <span>{item.alt}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════ TRUST ═══════ -->
<section id="trust" class="section-pad">
  <div class="wrap">
    <div class="trust-layout reveal">
      <div class="trust-statement">
        <h2>Người bạn địa phương<br/>của bạn ở Cao Bằng.</h2>
        <p class="trust-desc">
