---
import Base from '../../layouts/Base.astro';
import { programsData, vehicleGroups } from '../../data/programs';

export function getStaticPaths() {
  // Chỉ sinh trang cho chương trình đã phát hành (published)
  return programsData.filter((p) => p.published).map((p) => ({
    params: { id: p.id },
    props: { program: p },
  }));
}

const { program } = Astro.props;
const ZALO_LINK = 'https://zalo.me/0822946888';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<Base
  title={`${program.name} — Lịch trình Chi tiết Sen's Homestay (Cao Bằng)`}
  description={program.tagline}
>

<!-- ═══════ HEADER / NAV ═══════ -->
<nav id="detailNav">
  <div class="nav-inner">
    <a href={base} class="nav-back">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      <span>Trang chủ</span>
    </a>
    <span class="nav-title">{program.name}</span>
    <a href={ZALO_LINK} class="btn btn-zalo nav-cta" target="_blank" rel="noopener">Nhắn Zalo</a>
  </div>
</nav>

<!-- ═══════ HERO BANNER ═══════ -->
<header class="detail-hero">
  <div class="detail-hero-bg">
    <img src={`${base}${program.image}`} alt={program.name} class="detail-hero-img" />
    <div class="detail-hero-overlay"></div>
  </div>
  <div class="wrap detail-hero-content">
    <span class="hero-tag">Chuyến đi {program.days} ngày</span>
    <h1>{program.name}</h1>
    <p class="hero-tagline">{program.tagline}</p>
    <div class="hero-price">
      <span class="price-amount">{program.price}</span>
      <span class="price-note">{program.priceNote}</span>
    </div>
  </div>
</header>

<!-- ═══════ HIGHLIGHTS ═══════ -->
<section class="highlights-strip bg-surface">
  <div class="wrap">
    <div class="highlights-inner">
      <h2 class="highlights-lbl">Điểm nổi bật</h2>
      <ul class="highlights-list" style={`--hl-cols: ${Math.ceil(program.highlights.length / 2)}`}>
        {program.highlights.map(hl => (
          <li>
            <img src={`${base}${hl.image}`} alt={hl.name} loading="lazy" />
            <span>{hl.name}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<!-- ═══════ SERVICES TABS ═══════ -->
<section class="section-pad services-section">
  <div class="wrap">
    <div class="section-header">
      <h2>Dịch vụ đã lo trọn gói</h2>
      <p class="section-sub">Từng chi tiết nhỏ đã có Sen lo.</p>
    </div>
    
    <div class="services-container">
      <!-- Tabs Sidebar -->
      <div class="services-tabs" role="tablist">
        <button class="service-tab active" role="tab" aria-selected="true" data-tab="bus">
          <img class="tab-img" src={`${base}${program.busInfo.image}`} alt="" loading="lazy" />
          <div class="tab-txt">
            <strong>Xe khách</strong>
            <span>Giường phòng VIP</span>
          </div>
        </button>
        <button class="service-tab" role="tab" aria-selected="false" data-tab="motorbike">
          <img class="tab-img" src={`${base}${program.motorbikeInfo.image}`} alt="" loading="lazy" />
          <div class="tab-txt">
            <strong>Xe máy</strong>
            <span>Đầy bình xăng</span>
          </div>
        </button>
        <button class="service-tab" role="tab" aria-selected="false" data-tab="homestay">
          <img class="tab-img" src={`${base}${program.homestayInfo.image}`} alt="" loading="lazy" />
          <div class="tab-txt">
            <strong>Homestay</strong>
            <span>Sen's Homestay</span>
          </div>
        </button>
        {program.extraStayInfo && (
          <button class="service-tab" role="tab" aria-selected="false" data-tab="extrastay">
            <img class="tab-img" src={`${base}${program.extraStayInfo.image}`} alt="" loading="lazy" />
            <div class="tab-txt">
              <strong>{program.extraStayInfo.tabLabel}</strong>
              <span>{program.extraStayInfo.tabSub}</span>
            </div>
          </button>
        )}
        <button class="service-tab" role="tab" aria-selected="false" data-tab="night1">
          <img class="tab-img" src={`${base}${program.night1Info.image}`} alt="" loading="lazy" />
          <div class="tab-txt">
            <strong>Check-in sớm</strong>
            <span>Nghỉ sau xe đêm</span>
          </div>
        </button>
        <button class="service-tab" role="tab" aria-selected="false" data-tab="shower">
          <img class="tab-img" src={`${base}${program.showerInfo.image}`} alt="" loading="lazy" />
          <div class="tab-txt">
            <strong>Tắm trước khi về</strong>
            <span>Sạch sẽ lên xe đêm</span>
          </div>
        </button>
      </div>

      <!-- Tab Panels -->
      <div class="services-panels">
        <!-- Bus Panel -->
        <div class="service-panel active" id="panel-bus" role="tabpanel">
          <div class="panel-content">
            <div class="panel-info">
              <h3>{program.busInfo.title}</h3>
              <p class="panel-desc">{program.busInfo.desc}</p>
              <ul class="panel-details">
                {program.busInfo.details.map(d => <li>{d}</li>)}
              </ul>
            </div>
            <div class="panel-visual">
              <img src={`${base}${program.busInfo.image}`} alt={program.busInfo.title} />
            </div>
          </div>
        </div>
        
        <!-- Motorbike Panel -->
        <div class="service-panel" id="panel-motorbike" role="tabpanel">
          <div class="panel-content">
            <div class="panel-info">
              <h3>{program.motorbikeInfo.title}</h3>
              <p class="panel-desc">{program.motorbikeInfo.desc}</p>
              <ul class="panel-details">
                {program.motorbikeInfo.details.map(d => <li>{d}</li>)}
              </ul>
            </div>
            <div class="panel-visual">
              <img src={`${base}${program.motorbikeInfo.image}`} alt={program.motorbikeInfo.title} />
            </div>
          </div>
        </div>
        
        <!-- Homestay Panel -->
        <div class="service-panel" id="panel-homestay" role="tabpanel">
          <div class="panel-content">
            <div class="panel-info">
              <h3>{program.homestayInfo.title}</h3>
              <p class="panel-desc">{program.homestayInfo.desc}</p>
              <ul class="panel-details">
                {program.homestayInfo.details.map(d => <li>{d}</li>)}
              </ul>
            </div>
            <div class="panel-visual">
              <img src={`${base}${program.homestayInfo.image}`} alt={program.homestayInfo.title} />
            </div>
          </div>
        </div>
        
        <!-- Extra Stay Panel (VD: đêm Đồi Cỏ Cháy — chỉ tour có extraStayInfo) -->
        {program.extraStayInfo && (
          <div class="service-panel" id="panel-extrastay" role="tabpanel">
            <div class="panel-content">
              <div class="panel-info">
                <h3>{program.extraStayInfo.title}</h3>
                <p class="panel-desc">{program.extraStayInfo.desc}</p>
                <ul class="panel-details">
                  {program.extraStayInfo.details.map(d => <li>{d}</li>)}
                </ul>
              </div>
              <div class="panel-visual">
                <img src={`${base}${program.extraStayInfo.image}`} alt={program.extraStayInfo.title} />
              </div>
            </div>
          </div>
        )}

        <!-- Night 1 Panel -->
        <div class="service-panel" id="panel-night1" role="tabpanel">
          <div class="panel-content">
            <div class="panel-info">
              <h3>{program.night1Info.title}</h3>
              <p class="panel-desc">{program.night1Info.desc}</p>
              <ul class="panel-details">
                {program.night1Info.details.map(d => <li>{d}</li>)}
              </ul>
            </div>
            <div class="panel-visual">
              <img src={`${base}${program.night1Info.image}`} alt={program.night1Info.title} />
            </div>
          </div>
        </div>

        <!-- Shower Panel (tắm trước khi lên xe rời Cao Bằng) -->
        <div class="service-panel" id="panel-shower" role="tabpanel">
          <div class="panel-content">
            <div class="panel-info">
              <h3>{program.showerInfo.title}</h3>
              <p class="panel-desc">{program.showerInfo.desc}</p>
              <ul class="panel-details">
                {program.showerInfo.details.map(d => <li>{d}</li>)}
              </ul>
            </div>
            <div class="panel-visual">
              <img src={`${base}${program.showerInfo.image}`} alt={program.showerInfo.title} />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════ VEHICLE OPTIONS ═══════ -->
<section class="section-pad vehicle-section">
  <div class="wrap">
    <div class="section-header">
      <h2>Tuỳ chọn phương tiện</h2>
      <p class="section-sub">Mặc định là lựa chọn Sen thấy hợp. Muốn nâng cấp thì nhắn Zalo, phụ thu nói trước.</p>
    </div>

    <div class="vehicle-groups">
      {vehicleGroups.map(group => (
        <div class="vehicle-group" data-group={group.key}>
          <div class="vehicle-group-head">
            <h3>{group.label}</h3>
            {group.note && <span class="vehicle-group-note">{group.note}</span>}
          </div>
          <div class="vehicle-choices" role="radiogroup" aria-label={group.label}>
            {group.choices.map((choice, ci) => (
              <button
                type="button"
                class={`vehicle-choice ${choice.recommended ? 'selected' : ''}`}
                role="radio"
                aria-checked={choice.recommended ? 'true' : 'false'}
                data-index={ci}
              >
                <span class="vehicle-radio" aria-hidden="true"></span>
                {choice.image && (
                  <img class="vehicle-thumb" src={`${base}${choice.image}`} alt="" loading="lazy" />
                )}
                <span class="vehicle-choice-body">
                  <span class="vehicle-choice-head">
                    {choice.recommended && <span class="vehicle-badge">✦ Gợi ý</span>}
                    <span class="vehicle-choice-name">{choice.name}</span>
                  </span>
                  <span class="vehicle-choice-desc">{choice.desc}</span>
                </span>
                <span class={`vehicle-surcharge ${choice.surcharge === 'Đã bao gồm' ? 'included' : ''}`}>{choice.surcharge}</span>
              </button>
            ))}
          </div>
        </div>
      ))}
      <p class="vehicle-note">Sen xác nhận phụ thu qua Zalo — không phát sinh ngoài báo giá.</p>
    </div>
  </div>
</section>

<!-- ═══════ DETAILED ITINERARY ═══════ -->
<section class="section-pad itinerary-section bg-surface">
  <div class="itin-mist" style={`background-image: url(${base}images/sky-texture.jpg)`} aria-hidden="true"></div>
  <div class="wrap">
    <div class="section-header center">
      <h2>Lịch trình theo giờ</h2>
      <p class="section-sub">Sen sắp theo cung đường thực tế, để bạn đi vừa kịp vừa thong thả.</p>
    </div>

    <!-- Day Selector Tabs -->
    <div class="day-tabs">
      {program.itinerary.map((day, index) => (
        <button class={`day-tab ${index === 0 ? 'active' : ''}`} data-day={day.dayNumber}>
          <strong>Ngày {day.dayNumber}</strong>
          <span>{day.dayTitle}</span>
        </button>
      ))}
    </div>

    <!-- Daily Timelines -->
    <div class="daily-timelines">
      {program.itinerary.map((day, dayIdx) => (
        <div class={`daily-timeline ${dayIdx === 0 ? 'active' : ''}`} id={`timeline-day-${day.dayNumber}`}>
          <div class="timeline">
            <div class="timeline-line"></div>
            <div class="timeline-line-fill"></div>
            <div class="timeline-sun" aria-hidden="true">
              <svg class="sun-icon" viewBox="0 0 32 32">
                <defs>
                  <radialGradient id={`sunG${day.dayNumber}`} cx="50%" cy="42%" r="65%">
                    <stop offset="0%" stop-color="#FFE9A0" />
                    <stop offset="55%" stop-color="#F6B23F" />
                    <stop offset="100%" stop-color="#E58223" />
                  </radialGradient>
                </defs>
                <g stroke="#EFA83C" stroke-width="2" stroke-linecap="round">
                  <line x1="26" y1="16" x2="30.2" y2="16" />
                  <line x1="24.66" y1="21" x2="26.74" y2="22.2" />
                  <line x1="21" y1="24.66" x2="22.2" y2="26.74" />
                  <line x1="16" y1="26" x2="16" y2="30.2" />
                  <line x1="11" y1="24.66" x2="9.8" y2="26.74" />
                  <line x1="7.34" y1="21" x2="5.26" y2="22.2" />
                  <line x1="6" y1="16" x2="1.8" y2="16" />
                  <line x1="7.34" y1="11" x2="5.26" y2="9.8" />
                  <line x1="11" y1="7.34" x2="9.8" y2="5.26" />
                  <line x1="16" y1="6" x2="16" y2="1.8" />
                  <line x1="21" y1="7.34" x2="22.2" y2="5.26" />
                  <line x1="24.66" y1="11" x2="26.74" y2="9.8" />
                </g>
                <circle cx="16" cy="16" r="7" fill={`url(#sunG${day.dayNumber})`} />
              </svg>
              <svg class="moon-icon" viewBox="0 0 32 32">
                <defs>
                  <radialGradient id={`moonG${day.dayNumber}`} cx="40%" cy="35%" r="75%">
                    <stop offset="0%" stop-color="#FBF9EE" />
                    <stop offset="100%" stop-color="#D8D3EE" />
                  </radialGradient>
                  <mask id={`moonM${day.dayNumber}`}>
                    <rect width="32" height="32" fill="white" />
                    <circle cx="22.5" cy="10.5" r="8" fill="black" />
                  </mask>
                </defs>
                <g mask={`url(#moonM${day.dayNumber})`}>
                  <circle cx="15" cy="17" r="9.5" fill={`url(#moonG${day.dayNumber})`} />
                  <circle cx="11.5" cy="15" r="1.7" fill="#C7C1E3" opacity="0.75" />
                  <circle cx="15" cy="21.5" r="1.2" fill="#C7C1E3" opacity="0.6" />
                  <circle cx="9.5" cy="20" r="0.9" fill="#C7C1E3" opacity="0.55" />
                </g>
                <path d="M24 4.5l.8 2 2 .8-2 .8-.8 2-.8-2-2-.8 2-.8z" fill="#F3EFFC" />
                <path d="M28 12l.55 1.4 1.4.55-1.4.55L28 15.9l-.55-1.4-1.4-.55 1.4-.55z" fill="#F3EFFC" opacity="0.8" />
              </svg>
            </div>
            {day.activities.map((act, actIdx) => (
              <div class={`timeline-item reveal ${act.type ? `timeline-${act.type}` : ''}`} style={`--i: ${actIdx}`}>
                <div class="timeline-node"><span class="timeline-dot"></span></div>
                <div class="timeline-content">
                  <span class="timeline-time">{act.time}</span>
                  <h3 class="timeline-title">{act.title}</h3>
                  <p class="timeline-desc">{act.desc}</p>

                  {/* Điểm chính: bung sẵn — ảnh + chip thông tin + lưu ý */}
                  {act.type === 'sight' && (
                    <div class="sight-card">
                      {act.image && (
                        <div class="timeline-img-wrapper">
                          <img src={`${base}${act.image}`} alt={act.title} class="timeline-img" loading="lazy" />
                        </div>
                      )}
                      {act.chips && act.chips.length > 0 && (
                        <ul class="sight-chips">
                          {act.chips.map(c => <li class="sight-chip">{c}</li>)}
                        </ul>
                      )}
                      {act.tip && (
                        <div class="sight-tip">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 0 0-4 12.7V17a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1v-2.3A7 7 0 0 0 12 2z"/><line x1="9" y1="21" x2="15" y2="21"/></svg>
                          <span>{act.tip}</span>
                        </div>
                      )}
                    </div>
                  )}

                  {/* Mốc ăn: gọn — chạm bung 2 lựa chọn */}
                  {act.type === 'food' && act.options && act.options.length > 0 && (
                    <details class="food-choice">
                      <summary class="food-summary">
                        <span class="food-summary-label">
                          {act.options.length} lựa chọn · {(act.options.find(o => o.recommended) ?? act.options[0]).name}
                        </span>
                        <svg class="food-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                      </summary>
                      <div class="food-options">
                        {act.options.map(opt => (
                          <div class={`food-option ${opt.recommended ? 'recommended' : ''}`}>
                            {opt.image && (
                              <img class="food-option-img" src={`${base}${opt.image}`} alt={opt.name} loading="lazy" />
                            )}
                            <div class="food-option-body">
                              <div class="food-option-head">
                                {opt.recommended && <span class="food-badge">✦ Gợi ý</span>}
                                <span class="food-option-name">{opt.name}</span>
                              </div>
                              <div class="food-option-line">
                                {opt.price && <span class="food-option-price">{opt.price}</span>}
                                {opt.meta && <span class="food-option-meta">{opt.meta}</span>}
                              </div>
                              {opt.reason && <p class="food-option-reason">{opt.reason}</p>}
                            </div>
                          </div>
                        ))}
                      </div>
                    </details>
                  )}

                  {/* Mốc thường: giữ nguyên */}
                  {!act.type && act.image && (
                    <div class="timeline-img-wrapper">
                      <img src={`${base}${act.image}`} alt={act.title} class="timeline-img" loading="lazy" />
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════ FOOTER CTA ═══════ -->
<section class="section-pad bg-dark footer-cta-section">
  <div class="wrap footer-cta-wrap">
    <h2>Bạn muốn đi chuyến này?</h2>
    <p>Nhắn Zalo cho Sen ngày đi và số người. Sen ghép xe, phòng, lịch trình trong 5 phút.</p>
    <div class="cta-actions">
      <a href={ZALO_LINK} class="btn btn-primary btn-lg" target="_blank" rel="noopener">
        Nhắn Zalo — Đặt {program.name}
      </a>
      <a href={base} class="btn btn-outline hero-btn-outline btn-lg">Quay lại trang chủ</a>
    </div>
  </div>
</section>

<!-- ═══════ BOTTOM STICKY BOOKING BAR ═══════ -->
<div class="sticky-booking-bar" id="stickyBookingBar">
  <div class="sticky-booking-inner">
    <div class="sticky-booking-info">
      <h3>{program.name}</h3>
      <div class="sticky-booking-price">
        <strong>{program.price}</strong>
        <span>{program.priceNote}</span>
      </div>
    </div>
    <a href={ZALO_LINK} class="btn btn-zalo" target="_blank" rel="noopener">Đặt chuyến này</a>
  </div>
</div>

</Base>

<style>
/* ═══════ DETAIL NAV ═══════ */
#detailNav {
  position: fixed;
  inset: 0 0 auto 0;
  z-index: var(--z-sticky);
  background: oklch(1.000 0.000 0 / 0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  box-shadow: 0 1px 0 var(--line);
  height: 64px;
}
.nav-inner {
  max-width: var(--maxw);
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100%;
  padding-inline: var(--space-lg);
}
.nav-back {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-weight: 600;
  font-size: var(--text-sm);
  color: var(--muted);
  transition: color 0.25s;
}
.nav-back:hover { color: var(--ink); }
.nav-title {
  font-weight: 700;
  font-size: var(--text-base);
  color: var(--ink);
}

/* ═══════ HERO BANNER ═══════ */
.detail-hero {
  position: relative;
  padding-block: calc(64px + var(--space-2xl)) var(--space-2xl);
  color: white;
  min-height: 480px;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}
.detail-hero-bg {
  position: absolute;
  inset: 0;
}
.detail-hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.detail-hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, oklch(0.12 0.015 55 / 0.4) 0%, oklch(0.12 0.015 55 / 0.8) 100%);
}
.detail-hero-content {
  z-index: var(--z-raised);
  max-width: 800px;
}
.hero-tag {
  display: inline-block;
  background: var(--primary);
  color: var(--on-primary);
  font-weight: 700;
  font-size: var(--text-xs);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 6px 14px;
  border-radius: var(--r-pill);
  margin-bottom: var(--space-sm);
}
.detail-hero h1 {
  font-size: var(--text-3xl);
  color: white;
  margin-bottom: var(--space-sm);
  text-shadow: 0 2px 10px oklch(0.1 0.01 55 / 0.4);
}
.hero-tagline {
  font-size: var(--text-lg);
  color: oklch(0.9 0.005 55);
  margin-bottom: var(--space-md);
  text-shadow: 0 1px 6px oklch(0.1 0.01 55 / 0.4);
}
.hero-price {
  display: flex;
  align-items: baseline;
  gap: 6px;
}
.price-amount {
  font-size: var(--text-2xl);
  font-weight: 800;
  color: oklch(0.85 0.10 55);
}
.price-note {
  font-size: var(--text-sm);
  color: oklch(0.8 0.005 55);
}

/* ═══════ HIGHLIGHTS STRIP ═══════ */
.highlights-strip {
  padding-block: var(--space-md);
  border-bottom: 1px solid var(--line);
}
.highlights-inner {
  display: flex;
  align-items: center;
  gap: var(--space-lg);
  flex-wrap: wrap;
}
.highlights-lbl {
  font-size: var(--text-xs);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--muted);
  font-weight: 700;
}
/* Card ảnh nhỏ, desktop luôn 2 hàng (--hl-cols = ⌈n/2⌉ tính sẵn từ data) */
.highlights-list {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(var(--hl-cols, 4), 1fr);
  gap: var(--space-sm);
  flex: 1;
  min-width: 0;
}
.highlights-list li {
  background: var(--bg);
  border: 1px solid var(--line);
  border-radius: var(--r-sm);
  overflow: hidden;
  transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
}
.highlights-list li:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow-sm);
}
.highlights-list li img {
  display: block;
  width: 100%;
  aspect-ratio: 16 / 10;
  object-fit: cover;
}
.highlights-list li span {
  display: block;
  padding: 7px 8px;
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--ink);
  text-align: center;
  line-height: 1.3;
}
@media (max-width: 700px) {
  /* Mobile: nhãn lên trên, lưới 2 cột card to full chiều ngang */
  .highlights-inner { flex-direction: column; align-items: stretch; gap: var(--space-sm); }
  .highlights-list { grid-template-columns: repeat(2, 1fr); gap: var(--space-sm); }
  /* Tổng số lẻ → card cuối trải full ngang, không đứng lẻ nửa hàng */
  .highlights-list li:last-child:nth-child(odd) { grid-column: span 2; }
  .highlights-list li:last-child:nth-child(odd) img { aspect-ratio: 21 / 9; }
}

/* ═══════ SERVICES TABS ═══════ */
.services-section {
  background: var(--bg);
}
.services-container {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: var(--space-xl);
  margin-top: var(--space-xl);
}
.services-tabs {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.service-tab {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding: var(--space-md);
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: var(--r);
  text-align: left;
  transition: all 0.25s var(--ease-out);
}
.service-tab:hover {
  border-color: var(--primary);
  transform: translateX(4px);
}
.service-tab.active {
  background: var(--primary-soft);
  border-color: var(--primary);
}
.tab-img {
  width: 52px;
  height: 52px;
  border-radius: 10px;
  object-fit: cover;
  flex-shrink: 0;
}
.tab-txt {
  display: flex;
  flex-direction: column;
}
.tab-txt strong {
  font-size: var(--text-base);
  color: var(--ink);
}
.tab-txt span {
  font-size: var(--text-xs);
  color: var(--muted);
}
.services-panels {
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: var(--r-lg);
  overflow: hidden;
}
.service-panel {
  display: none;
}
.service-panel.active {
  display: block;
}
.panel-content {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  min-height: 380px;
}
.panel-info {
  padding: var(--space-lg);
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.panel-info h3 {
  font-size: var(--text-xl);
  margin-bottom: var(--space-sm);
  color: var(--ink);
}
.panel-desc {
  font-size: var(--text-base);
  color: var(--muted);
  margin-bottom: var(--space-md);
}
.panel-details {
  list-style: none;
}
.panel-details li {
  position: relative;
  padding-left: var(--space-md);
  font-size: var(--text-sm);
  color: var(--ink);
  margin-bottom: 8px;
  line-height: 1.6;
}
.panel-details li::before {
  content: '•';
  position: absolute;
  left: 0;
  color: var(--primary);
  font-weight: 700;
}
.panel-visual {
  overflow: hidden;
  height: 100%;
}
.panel-visual img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ═══════ ITINERARY ═══════ */
.itinerary-section {
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
  position: relative;
}
/* Lớp sương (texture grayscale đều, tile seamless) blend lên gradient bầu
   trời — tự nhuộm theo màu trời khi cuộn, nằm dưới card */
.itin-mist {
  position: absolute;
  inset: 0;
  /* Tile lặp kích thước cố định — không kéo giãn theo chiều cao section */
  background-size: 1000px auto;
  background-repeat: repeat;
  mix-blend-mode: overlay;
  opacity: 0.55;
  pointer-events: none;
}
@media (max-width: 600px) {
  .itin-mist { background-size: 640px auto; }
}
.itinerary-section > .wrap {
  position: relative;
  z-index: var(--z-base);
}
.day-tabs {
  display: flex;
  justify-content: center;
  gap: var(--space-sm);
  margin-block: var(--space-lg) var(--space-xl);
  flex-wrap: wrap;
}
.day-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12px 24px;
  background: var(--bg);
  border: 1px solid var(--line);
  border-radius: var(--r);
  cursor: pointer;
  transition: all 0.25s var(--ease-out);
}
.day-tab:hover {
  border-color: var(--primary);
}
.day-tab.active {
  background: var(--primary);
  border-color: var(--primary);
  color: var(--on-primary);
}
.day-tab strong {
  font-size: var(--text-base);
}
.day-tab span {
  font-size: var(--text-xs);
  opacity: 0.9;
}
.day-tab.active span {
  color: var(--on-primary);
}
.daily-timeline {
  display: none;
  max-width: 820px;
  margin: 0 auto;
}
.daily-timeline.active {
  display: block;
}
/* ── Timeline: mobile = 1 cột line trái; desktop = line giữa, card so le ── */
.timeline {
  position: relative;
}
.timeline-line {
  position: absolute;
  left: 11px;
  top: 6px;
  bottom: 6px;
  width: 2px;
  background: var(--line-strong);
}
.timeline-item {
  position: relative;
  padding-left: 40px;
  padding-bottom: var(--space-lg);
  transition-delay: calc(var(--i, 0) * 50ms);
}
.timeline-item:last-child { padding-bottom: 0; }
.timeline-node {
  position: absolute;
  left: 0;
  top: 4px;
  width: 24px;
  display: flex;
  justify-content: center;
  z-index: var(--z-raised);
}
.timeline-dot {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: var(--primary);
  box-shadow: 0 0 0 4px var(--primary-soft);
  transition: background 0.35s var(--ease-out), box-shadow 0.35s var(--ease-out);
}
/* Mốc chưa tới (dưới mặt trời) → mờ đi; mặc định (no-JS) = sáng */
.timeline-item.upcoming .timeline-dot {
  background: var(--line-strong);
  box-shadow: 0 0 0 4px var(--surface);
}

/* Đường "đã đi" chồng lên line + chấm mặt trời chạy theo scroll */
.timeline-line-fill {
  position: absolute;
  left: 11px;
  top: 6px;
  width: 2px;
  height: calc(var(--sun, 0) * (100% - 12px));
  background: linear-gradient(180deg, var(--primary-soft), var(--primary));
  border-radius: 2px;
  z-index: 1;
}
.timeline-sun {
  position: absolute;
  left: 12px;
  top: calc(6px + var(--sun, 0) * (100% - 12px));
  width: 26px;
  height: 26px;
  margin: -13px 0 0 -13px;
  z-index: 4;
  pointer-events: none;
}
.timeline-sun svg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  transition: opacity 0.5s var(--ease-out), transform 0.5s var(--ease-out);
}
.sun-icon {
  filter: drop-shadow(0 0 5px oklch(0.80 0.15 70 / 0.55));
}
/* Cuối ngày (p > 0.7, trời chuyển tím) mặt trời lặn → trăng lưỡi liềm mọc */
.moon-icon {
  filter: drop-shadow(0 0 5px oklch(0.72 0.06 295 / 0.6));
  opacity: 0;
  transform: rotate(-90deg) scale(0.4);
}
.timeline-sun.night .sun-icon {
  opacity: 0;
  transform: rotate(90deg) scale(0.4);
}
.timeline-sun.night .moon-icon {
  opacity: 1;
  transform: none;
}
@media (min-width: 900px) {
  .timeline-line-fill { left: 50%; margin-left: -1px; }
  .timeline-sun { left: 50%; }
}
@media (prefers-reduced-motion: reduce) {
  .timeline-sun { display: none; }
}
.timeline-content {
  position: relative;
  border: 1px solid var(--line);
  border-radius: var(--r);
  background: var(--bg);
  padding: var(--space-md);
  box-shadow: var(--shadow-sm);
}
.timeline-time {
  display: inline-block;
  font-size: var(--text-xs);
  font-weight: 800;
  color: var(--primary-hover);
  background: var(--primary-soft);
  padding: 3px 10px;
  border-radius: var(--r-pill);
  font-variant-numeric: tabular-nums;
  margin-bottom: 8px;
}
.timeline-title {
  font-size: var(--text-lg);
  font-weight: 700;
  margin-bottom: 4px;
}
.timeline-desc {
  font-size: var(--text-sm);
  color: var(--muted);
  line-height: 1.6;
}

/* Desktop ≥900px: line giữa, card so le trái/phải + connector */
@media (min-width: 900px) {
  .timeline-line {
    left: 50%;
    transform: translateX(-50%);
  }
  .timeline-item {
    padding-left: 0;
    padding-bottom: var(--space-xl);
  }
  .timeline-node {
    left: 50%;
    transform: translateX(-50%);
  }
  .timeline-content {
    width: calc(50% - 34px);
  }
  .timeline-item:nth-child(odd) .timeline-content { margin-right: auto; }
  .timeline-item:nth-child(even) .timeline-content { margin-left: auto; }
  .timeline-item:nth-child(odd) .timeline-content::after {
    content: '';
    position: absolute;
    top: 12px;
    right: -34px;
    width: 34px;
    height: 2px;
    background: var(--line-strong);
  }
  .timeline-item:nth-child(even) .timeline-content::after {
    content: '';
    position: absolute;
    top: 12px;
    left: -34px;
    width: 34px;
    height: 2px;
    background: var(--line-strong);
  }
}
.timeline-img-wrapper {
  margin-top: var(--space-sm);
  border-radius: var(--r);
  overflow: hidden;
  aspect-ratio: 16 / 9;
  max-width: 480px;
  border: 1px solid var(--line);
  box-shadow: var(--shadow-sm);
}
.timeline-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ── Điểm chính (sight): dot to hơn để nổi bật ── */
.timeline-sight .timeline-dot {
  width: 16px;
  height: 16px;
  box-shadow: 0 0 0 5px var(--primary-soft);
}
.timeline-sight .timeline-title {
  font-size: var(--text-xl);
}

/* ── Sight card: chip thông tin + lưu ý ── */
.sight-chips {
  list-style: none;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: var(--space-sm);
}
.sight-chip {
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--ink);
  background: var(--bg);
  border: 1px solid var(--line);
  padding: 5px 12px;
  border-radius: var(--r-pill);
}
.sight-tip {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  margin-top: var(--space-sm);
  padding: 10px 14px;
  background: var(--primary-soft);
  border-radius: var(--r);
  font-size: var(--text-sm);
  color: var(--ink);
  line-height: 1.55;
}
.sight-tip svg {
  color: var(--primary);
  flex-shrink: 0;
  margin-top: 2px;
}

/* ── Food choice: accordion 2 lựa chọn ── */
.food-choice {
  margin-top: var(--space-sm);
  border: 1px solid var(--line);
  border-radius: var(--r);
  background: var(--bg);
  overflow: hidden;
}
.food-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 12px 14px;
  cursor: pointer;
  list-style: none;
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--ink);
}
.food-summary::-webkit-details-marker { display: none; }
.food-summary::marker { content: ''; }
.food-chevron {
  flex-shrink: 0;
  color: var(--muted);
  transition: transform 0.3s var(--ease-out);
}
.food-choice[open] .food-chevron { transform: rotate(180deg); }
.food-options {
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 0 14px 14px;
}
.food-option {
  display: flex;
  gap: 12px;
  padding: 12px;
  border: 1px solid var(--line);
  border-radius: var(--r-sm);
  background: var(--surface);
}
.food-option.recommended {
  border-color: var(--primary);
  background: var(--primary-soft);
  box-shadow: 0 0 0 1px var(--primary);
}
.food-option-img {
  width: 68px;
  height: 68px;
  border-radius: var(--r-sm);
  object-fit: cover;
  flex-shrink: 0;
}
.food-option-body {
  display: flex;
  flex-direction: column;
  gap: 3px;
  min-width: 0;
}
.food-option-head {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}
.food-badge {
  font-size: var(--text-xs);
  font-weight: 800;
  color: var(--on-primary);
  background: var(--primary);
  padding: 2px 8px;
  border-radius: var(--r-pill);
  white-space: nowrap;
}
.food-option-name {
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--ink);
}
.food-option-line {
  display: flex;
  align-items: baseline;
  gap: 8px;
  flex-wrap: wrap;
}
.food-option-price {
  font-size: var(--text-sm);
  font-weight: 700;
  color: var(--primary);
}
.food-option-meta {
  font-size: var(--text-xs);
  color: var(--muted);
}
.food-option-reason {
  font-size: var(--text-sm);
  color: var(--muted);
  line-height: 1.5;
}

/* ═══════ VEHICLE OPTIONS ═══════ */
.vehicle-groups {
  display: flex;
  flex-direction: column;
  gap: var(--space-xl);
  max-width: 960px;
}
.vehicle-group-head {
  display: flex;
  align-items: baseline;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: var(--space-sm);
}
.vehicle-group-head h3 { font-size: var(--text-lg); }
.vehicle-group-note { font-size: var(--text-sm); color: var(--muted); }
/* Card ảnh chủ đạo: ảnh full-width trên, radio nổi trên ảnh, text gọn dưới */
.vehicle-choices {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 12px;
}
.vehicle-choice {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  position: relative;
  width: 100%;
  text-align: left;
  padding: 0;
  overflow: hidden;
  border: 1px solid var(--line);
  border-radius: var(--r);
  background: var(--bg);
  cursor: pointer;
  transition: border-color 0.2s var(--ease-out), background 0.2s var(--ease-out), box-shadow 0.2s var(--ease-out);
}
.vehicle-choice:hover { border-color: var(--primary); }
.vehicle-choice.selected {
  border-color: var(--primary);
  background: var(--primary-soft);
  box-shadow: 0 0 0 1px var(--primary);
}
.vehicle-radio {
  position: absolute;
  top: 10px;
  left: 10px;
  z-index: var(--z-base);
  width: 22px;
  height: 22px;
  border-radius: 50%;
  border: 2px solid oklch(1 0 0 / 0.9);
  background: rgba(20, 15, 10, 0.35);
  backdrop-filter: blur(2px);
  -webkit-backdrop-filter: blur(2px);
  flex-shrink: 0;
  transition: border-color 0.2s, background 0.2s;
}
.vehicle-choice.selected .vehicle-radio {
  border-color: #fff;
  background: var(--primary);
}
.vehicle-choice.selected .vehicle-radio::after {
  content: '';
  position: absolute;
  inset: 4px;
  border-radius: 50%;
  background: #fff;
}
.vehicle-choice-body {
  display: flex;
  flex-direction: column;
  gap: 3px;
  flex: 1;
  min-width: 0;
  padding: 10px 12px 2px;
}
.vehicle-choice-head {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}
.vehicle-badge {
  font-size: var(--text-xs);
  font-weight: 800;
  color: var(--on-primary);
  background: var(--primary);
  padding: 2px 8px;
  border-radius: var(--r-pill);
  white-space: nowrap;
}
.vehicle-choice-name {
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--ink);
}
.vehicle-choice-desc {
  font-size: var(--text-sm);
  color: var(--muted);
  line-height: 1.5;
}
.vehicle-surcharge {
  padding: 4px 12px 12px;
  font-size: var(--text-sm);
  font-weight: 700;
  color: var(--primary);
  white-space: nowrap;
}
.vehicle-surcharge.included {
  color: var(--muted);
  font-weight: 600;
}
/* Ảnh là nhân vật chính — full-width, chiếm phần lớn card */
.vehicle-thumb {
  width: 100%;
  height: auto;
  aspect-ratio: 16 / 10;
  object-fit: cover;
  flex-shrink: 0;
  order: -1; /* ảnh luôn lên đầu, trước radio trong DOM */
}
.vehicle-note {
  font-size: var(--text-sm);
  color: var(--muted);
  margin-top: 4px;
}

/* ═══════ FOOTER CTA ═══════ */
.footer-cta-section {
  text-align: center;
  padding-bottom: 120px;
}
.footer-cta-wrap h2 {
  color: white;
  font-size: var(--text-2xl);
  margin-bottom: var(--space-sm);
}
.footer-cta-wrap p {
  color: var(--dark-muted);
  font-size: var(--text-base);
  max-width: 50ch;
  margin: 0 auto var(--space-xl);
}
.cta-actions {
  display: flex;
  gap: var(--space-md);
  justify-content: center;
  flex-wrap: wrap;
}

/* ═══════ STICKY BOOKING BAR ═══════ */
.sticky-booking-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: var(--z-sticky);
  background: oklch(1.000 0.000 0 / 0.95);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow: 0 -2px 12px oklch(0.2 0.01 55 / 0.1);
  padding: 12px var(--space-lg);
  padding-bottom: max(12px, env(safe-area-inset-bottom));
  transform: translateY(0);
  transition: transform 0.4s var(--ease-out);
}
.sticky-booking-inner {
  max-width: var(--maxw);
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.sticky-booking-info h3 {
  font-size: var(--text-sm);
  color: var(--muted);
  font-weight: 500;
}
.sticky-booking-price {
  display: flex;
  align-items: baseline;
  gap: 4px;
}
.sticky-booking-price strong {
  font-size: var(--text-lg);
  color: var(--primary);
  font-weight: 800;
}
.sticky-booking-price span {
  font-size: var(--text-xs);
  color: var(--muted);
}

/* ═══════ RESPONSIVE ═══════ */
@media (max-width: 900px) {
  .services-container {
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }
  /* Mobile: lưới thấy đủ 4 tab cùng lúc — không bắt khách vuốt ngang */
  .services-tabs {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 10px;
  }
  .service-tab {
    padding: var(--space-sm);
    flex-direction: column;
    text-align: center;
    gap: var(--space-xs);
  }
  .service-tab:hover {
    transform: none;
  }
  /* Mobile: ảnh thumb trải full ngang tab như mini-card */
  .tab-img {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
  }
  .tab-txt strong {
    font-size: var(--text-sm);
  }
  .panel-content {
    grid-template-columns: 1fr;
  }
  .panel-visual {
    order: -1;
    height: 220px;
  }
}

@media (max-width: 600px) {
  /* Sticky booking bar dưới đã lo CTA — ẩn nút Zalo trên nav để khỏi lặp
     và nhường chỗ cho tên tour hiển thị đủ */
  #detailNav .nav-cta { display: none; }
  #detailNav .nav-title {
    flex: 1;
    text-align: right;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .detail-hero {
    min-height: 380px;
  }
  .detail-hero h1 {
    font-size: var(--text-2xl);
  }

  /* ── Dịch vụ: gọn cho mobile — ảnh thấp, 2 ý chính, bớt chữ ── */
  .panel-content { min-height: 0; }
  .panel-visual { height: 180px; }
  .panel-info { padding: var(--space-md); }
  .panel-desc {
    font-size: var(--text-sm);
    margin-bottom: var(--space-sm);
  }
  .panel-details li { font-size: var(--text-xs); margin-bottom: 6px; }
  .panel-details li:nth-child(n+3) { display: none; }

  /* ── Vehicle: lưới 2 cột card ảnh, ẩn mô tả — ảnh nói thay chữ ── */
  .vehicle-choices { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .vehicle-choice-desc { display: none; }
  .vehicle-choice-name { font-size: var(--text-sm); }
  /* Nhóm số lẻ lựa chọn → card cuối trải full ngang */
  .vehicle-choice:last-child:nth-child(odd) { grid-column: span 2; }
  .vehicle-choice:last-child:nth-child(odd) .vehicle-thumb { aspect-ratio: 21 / 9; }
}
</style>

<script>
  // Services Tab Switcher
  const tabs = document.querySelectorAll('.service-tab');
  const panels = document.querySelectorAll('.service-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      // Deactivate all tabs & panels
      tabs.forEach(t => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      panels.forEach(p => p.classList.remove('active'));

      // Activate clicked tab & panel
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      const tabName = tab.getAttribute('data-tab');
      const targetPanel = document.getElementById(`panel-${tabName}`);
      targetPanel?.classList.add('active');
    });
  });

  // Day Timeline Switcher
  const dayTabs = document.querySelectorAll('.day-tab');
  const timelines = document.querySelectorAll('.daily-timeline');

  dayTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      // Deactivate all day tabs & timelines
      dayTabs.forEach(t => t.classList.remove('active'));
      timelines.forEach(tl => tl.classList.remove('active'));

      // Activate clicked tab & timeline
      tab.classList.add('active');
      const dayNum = tab.getAttribute('data-day');
      const targetTimeline = document.getElementById(`timeline-day-${dayNum}`);
      targetTimeline?.classList.add('active');

      // Scroll reveal trigger check
      window.dispatchEvent(new Event('scroll'));
    });
  });

  // Vehicle option selection (radio behavior within each group)
  document.querySelectorAll('.vehicle-group').forEach(group => {
    const choices = group.querySelectorAll('.vehicle-choice');
    choices.forEach(choice => {
      choice.addEventListener('click', () => {
        choices.forEach(c => {
          c.classList.remove('selected');
          c.setAttribute('aria-checked', 'false');
        });
        choice.classList.add('selected');
        choice.setAttribute('aria-checked', 'true');
      });
    });
  });

  // Simple Scroll Reveal integration on page switch
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  reveals.forEach(el => observer.observe(el));

  // ── Timeline: mặt trời chạy theo scroll + nền đổi màu sáng→tối ──
  const itinSection = document.querySelector('.itinerary-section');
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)');
  // "Bầu trời thật" — màu lấy từ trời, giảm bão hoà cho tinh tế nhưng vẫn rõ.
  // Sáng cerulean dịu → trưa kem nắng → chiều đào golden-hour → tối tím periwinkle.
  const SKY = [196, 219, 236], NOON = [244, 235, 203], GOLD = [241, 204, 166], DUSK = [206, 197, 226];
  const lerp = (a, b, t) => Math.round(a + (b - a) * t);
  const mix = (c1, c2, t) => [lerp(c1[0], c2[0], t), lerp(c1[1], c2[1], t), lerp(c1[2], c2[2], t)];
  const dayColorArr = (p) => {
    if (p < 1 / 3) return mix(SKY, NOON, p / (1 / 3));
    if (p < 2 / 3) return mix(NOON, GOLD, (p - 1 / 3) / (1 / 3));
    return mix(GOLD, DUSK, (p - 2 / 3) / (1 / 3));
  };
  // "Bầu trời": gradient dọc — trên sáng nhạt (trời cao, pha sương trắng),
  // dưới đậm dần (chân trời). Lấy cảm hứng từ dải sương tan trong ảnh generate.
  const skyGradient = (p) => {
    const horizon = dayColorArr(p);
    const zenith = mix(horizon, [255, 255, 255], 0.55);
    return `linear-gradient(180deg, rgb(${zenith}) 0%, rgb(${horizon}) 100%)`;
  };

  let tlTicking = false;
  function updateTimelineSun() {
    tlTicking = false;
    const tl = document.querySelector('.daily-timeline.active .timeline');
    if (!tl) return;
    const sunEl = tl.querySelector('.timeline-sun');
    if (prefersReduced.matches) {
      tl.style.setProperty('--sun', '0');
      tl.querySelectorAll('.timeline-item').forEach(it => it.classList.remove('upcoming'));
      sunEl?.classList.remove('night');
      if (itinSection) itinSection.style.background = skyGradient(0.2);
      return;
    }
    const rect = tl.getBoundingClientRect();
    const ref = window.innerHeight * 0.45;
    let p = (ref - rect.top) / rect.height;
    p = Math.max(0, Math.min(1, p));
    tl.style.setProperty('--sun', p.toFixed(4));
    // Qua 70% ngày (trời vào pha tím hoàng hôn) → trăng thay mặt trời
    sunEl?.classList.toggle('night', p > 0.7);
    if (itinSection) itinSection.style.background = skyGradient(p);
    const sunY = p * rect.height;
    tl.querySelectorAll('.timeline-item').forEach(it => {
      it.classList.toggle('upcoming', it.offsetTop > sunY + 4);
    });
  }
  function onTlScroll() {
    if (!tlTicking) { tlTicking = true; requestAnimationFrame(updateTimelineSun); }
  }
  window.addEventListener('scroll', onTlScroll, { passive: true });
  window.addEventListener('resize', onTlScroll, { passive: true });
  updateTimelineSun();
</script>
