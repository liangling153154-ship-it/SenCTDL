---
import Base from '../../layouts/Base.astro';
import { programsData } from '../../data/programs';

export function getStaticPaths() {
  return programsData.map((p) => ({
    params: { id: p.id },
    props: { program: p },
  }));
}

const { program } = Astro.props;
const ZALO_LINK = 'https://zalo.me/0822946888';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<Base
  title={`${program.name} — Lịch trình Chi tiết Sen's Homestay (Cao Bằng)`}
  description={program.tagline}
>

<!-- ═══════ HEADER / NAV ═══════ -->
<nav id="detailNav">
  <div class="nav-inner">
    <a href={base} class="nav-back">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      <span>Trang chủ</span>
    </a>
    <span class="nav-title">{program.name}</span>
    <a href={ZALO_LINK} class="btn btn-zalo nav-cta" target="_blank" rel="noopener">Nhắn Zalo</a>
  </div>
</nav>

<!-- ═══════ HERO BANNER ═══════ -->
<header class="detail-hero">
  <div class="detail-hero-bg">
    <img src={`${base}${program.image}`} alt={program.name} class="detail-hero-img" />
    <div class="detail-hero-overlay"></div>
  </div>
  <div class="wrap detail-hero-content">
    <span class="hero-tag">Chương trình {program.days} Ngày</span>
    <h1>{program.name}</h1>
    <p class="hero-tagline">{program.tagline}</p>
    <div class="hero-price">
      <span class="price-amount">{program.price}</span>
      <span class="price-note">{program.priceNote}</span>
    </div>
  </div>
</header>

<!-- ═══════ HIGHLIGHTS ═══════ -->
<section class="highlights-strip bg-surface">
  <div class="wrap">
    <div class="highlights-inner">
      <h2 class="highlights-lbl">Điểm nổi bật</h2>
      <ul class="highlights-list">
        {program.highlights.map(hl => (
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>{hl}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<!-- ═══════ SERVICES TABS ═══════ -->
<section class="section-pad services-section">
  <div class="wrap">
    <div class="section-header">
      <h2>Dịch vụ đã lo trọn gói</h2>
      <p class="section-sub">Chúng tôi thiết kế và vận hành từng chi tiết nhỏ nhất trong chuyến đi của bạn.</p>
    </div>
    
    <div class="services-container">
      <!-- Tabs Sidebar -->
      <div class="services-tabs" role="tablist">
        <button class="service-tab active" role="tab" aria-selected="true" data-tab="bus">
          <span class="tab-icon">🚌</span>
          <div class="tab-txt">
            <strong>Xe khách</strong>
            <span>Giường phòng VIP</span>
          </div>
        </button>
        <button class="service-tab" role="tab" aria-selected="false" data-tab="motorbike">
          <span class="tab-icon">🏍️</span>
          <div class="tab-txt">
            <strong>Xe máy thuê</strong>
            <span>Đầy bình xăng</span>
          </div>
        </button>
        <button class="service-tab" role="tab" aria-selected="false" data-tab="homestay">
          <span class="tab-icon">🏡</span>
          <div class="tab-txt">
            <strong>Homestay</strong>
            <span>Sen's Homestay</span>
          </div>
        </button>
        <button class="service-tab" role="tab" aria-selected="false" data-tab="night1">
          <span class="tab-icon">🌙</span>
          <div class="tab-txt">
            <strong>Đêm thứ 1</strong>
            <span>Ngủ xe dưỡng sức</span>
          </div>
        </button>
      </div>

      <!-- Tab Panels -->
      <div class="services-panels">
        <!-- Bus Panel -->
        <div class="service-panel active" id="panel-bus" role="tabpanel">
          <div class="panel-content">
            <div class="panel-info">
              <h3>{program.busInfo.title}</h3>
              <p class="panel-desc">{program.busInfo.desc}</p>
              <ul class="panel-details">
                {program.busInfo.details.map(d => <li>{d}</li>)}
              </ul>
            </div>
            <div class="panel-visual">
              <img src={`${base}${program.busInfo.image}`} alt={program.busInfo.title} />
            </div>
          </div>
        </div>
        
        <!-- Motorbike Panel -->
        <div class="service-panel" id="panel-motorbike" role="tabpanel">
          <div class="panel-content">
            <div class="panel-info">
              <h3>{program.motorbikeInfo.title}</h3>
              <p class="panel-desc">{program.motorbikeInfo.desc}</p>
              <ul class="panel-details">
                {program.motorbikeInfo.details.map(d => <li>{d}</li>)}
              </ul>
            </div>
            <div class="panel-visual">
              <img src={`${base}${program.motorbikeInfo.image}`} alt={program.motorbikeInfo.title} />
            </div>
          </div>
        </div>
        
        <!-- Homestay Panel -->
        <div class="service-panel" id="panel-homestay" role="tabpanel">
          <div class="panel-content">
            <div class="panel-info">
              <h3>{program.homestayInfo.title}</h3>
              <p class="panel-desc">{program.homestayInfo.desc}</p>
              <ul class="panel-details">
                {program.homestayInfo.details.map(d => <li>{d}</li>)}
              </ul>
            </div>
            <div class="panel-visual">
              <img src={`${base}${program.homestayInfo.image}`} alt={program.homestayInfo.title} />
            </div>
          </div>
        </div>
        
        <!-- Night 1 Panel -->
        <div class="service-panel" id="panel-night1" role="tabpanel">
          <div class="panel-content">
            <div class="panel-info">
              <h3>{program.night1Info.title}</h3>
              <p class="panel-desc">{program.night1Info.desc}</p>
              <ul class="panel-details">
                {program.night1Info.details.map(d => <li>{d}</li>)}
              </ul>
            </div>
            <div class="panel-visual">
              <img src={`${base}${program.night1Info.image}`} alt={program.night1Info.title} />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════ DETAILED ITINERARY ═══════ -->
<section class="section-pad itinerary-section bg-surface">
  <div class="wrap">
    <div class="section-header center">
      <h2>Lịch trình thiết kế chi tiết</h2>
      <p class="section-sub">Được chuẩn bị chính xác theo giờ dựa trên trải nghiệm thực tế tốt nhất.</p>
    </div>

    <!-- Day Selector Tabs -->
    <div class="day-tabs">
      {program.itinerary.map((day, index) => (
        <button class={`day-tab ${index === 0 ? 'active' : ''}`} data-day={day.dayNumber}>
          <strong>Ngày {day.dayNumber}</strong>
          <span>{day.dayTitle}</span>
        </button>
      ))}
    </div>

    <!-- Daily Timelines -->
    <div class="daily-timelines">
      {program.itinerary.map((day, dayIdx) => (
        <div class={`daily-timeline ${dayIdx === 0 ? 'active' : ''}`} id={`timeline-day-${day.dayNumber}`}>
          <div class="timeline">
            <div class="timeline-line"></div>
            {day.activities.map((act, actIdx) => (
              <div class="timeline-item reveal" style={`--i: ${actIdx}`}>
                <div class="timeline-marker">
                  <div class="timeline-dot"></div>
                  <span class="timeline-time">{act.time}</span>
                </div>
                <div class="timeline-content">
                  <h3 class="timeline-title">{act.title}</h3>
                  <p class="timeline-desc">{act.desc}</p>
                  {act.image && (
                    <div class="timeline-img-wrapper">
                      <img src={`${base}${act.image}`} alt={act.title} class="timeline-img" loading="lazy" />
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════ FOOTER CTA ═══════ -->
<section class="section-pad bg-dark footer-cta-section">
  <div class="wrap footer-cta-wrap">
    <h2>Bạn muốn trải nghiệm chuyến đi này?</h2>
    <p>Chỉ cần nhắn Zalo cho chúng tôi ngày đi và số người. Mọi kế hoạch, xe cộ, phòng ốc sẽ được thiết kế xong trong 5 phút.</p>
    <div class="cta-actions">
      <a href={ZALO_LINK} class="btn btn-primary btn-lg" target="_blank" rel="noopener">
        Nhắn Zalo — Đặt {program.name}
      </a>
      <a href={base} class="btn btn-outline hero-btn-outline btn-lg">Quay lại trang chủ</a>
    </div>
  </div>
</section>

<!-- ═══════ BOTTOM STICKY BOOKING BAR ═══════ -->
<div class="sticky-booking-bar" id="stickyBookingBar">
  <div class="sticky-booking-inner">
    <div class="sticky-booking-info">
      <h3>{program.name}</h3>
      <div class="sticky-booking-price">
        <strong>{program.price}</strong>
        <span>{program.priceNote}</span>
      </div>
    </div>
    <a href={ZALO_LINK} class="btn btn-zalo" target="_blank" rel="noopener">Đặt lịch trình này</a>
  </div>
</div>

</Base>

<style>
/* ═══════ DETAIL NAV ═══════ */
#detailNav {
  position: fixed;
  inset: 0 0 auto 0;
  z-index: var(--z-sticky);
  background: oklch(1.000 0.000 0 / 0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  box-shadow: 0 1px 0 var(--line);
  height: 64px;
}
.nav-inner {
  max-width: var(--maxw);
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100%;
  padding-inline: var(--space-lg);
}
.nav-back {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-weight: 600;
  font-size: var(--text-sm);
  color: var(--muted);
  transition: color 0.25s;
}
.nav-back:hover { color: var(--ink); }
.nav-title {
  font-weight: 700;
  font-size: var(--text-base);
  color: var(--ink);
}

/* ═══════ HERO BANNER ═══════ */
.detail-hero {
  position: relative;
  padding-block: calc(64px + var(--space-2xl)) var(--space-2xl);
  color: white;
  min-height: 480px;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}
.detail-hero-bg {
  position: absolute;
  inset: 0;
}
.detail-hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.detail-hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, oklch(0.12 0.015 55 / 0.4) 0%, oklch(0.12 0.015 55 / 0.8) 100%);
}
.detail-hero-content {
  z-index: var(--z-raised);
  max-width: 800px;
}
.hero-tag {
  display: inline-block;
  background: var(--primary);
  color: var(--on-primary);
  font-weight: 700;
  font-size: var(--text-xs);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 6px 14px;
  border-radius: var(--r-pill);
  margin-bottom: var(--space-sm);
}
.detail-hero h1 {
  font-size: var(--text-3xl);
  color: white;
  margin-bottom: var(--space-sm);
  text-shadow: 0 2px 10px oklch(0.1 0.01 55 / 0.4);
}
.hero-tagline {
  font-size: var(--text-lg);
  color: oklch(0.9 0.005 55);
  margin-bottom: var(--space-md);
  text-shadow: 0 1px 6px oklch(0.1 0.01 55 / 0.4);
}
.hero-price {
  display: flex;
  align-items: baseline;
  gap: 6px;
}
.price-amount {
  font-size: var(--text-2xl);
  font-weight: 800;
  color: oklch(0.85 0.10 55);
}
.price-note {
  font-size: var(--text-sm);
  color: oklch(0.8 0.005 55);
}

/* ═══════ HIGHLIGHTS STRIP ═══════ */
.highlights-strip {
  padding-block: var(--space-md);
  border-bottom: 1px solid var(--line);
}
.highlights-inner {
  display: flex;
  align-items: center;
  gap: var(--space-lg);
  flex-wrap: wrap;
}
.highlights-lbl {
  font-size: var(--text-xs);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--muted);
  font-weight: 700;
}
.highlights-list {
  list-style: none;
  display: flex;
  gap: var(--space-md);
  flex-wrap: wrap;
  flex: 1;
}
.highlights-list li {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--ink);
  background: var(--bg);
  padding: 8px 16px;
  border-radius: var(--r-sm);
  border: 1px solid var(--line);
}
.highlights-list li svg {
  color: var(--accent);
}

/* ═══════ SERVICES TABS ═══════ */
.services-section {
  background: var(--bg);
}
.services-container {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: var(--space-xl);
  margin-top: var(--space-xl);
}
.services-tabs {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.service-tab {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding: var(--space-md);
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: var(--r);
  text-align: left;
  transition: all 0.25s var(--ease-out);
}
.service-tab:hover {
  border-color: var(--primary);
  transform: translateX(4px);
}
.service-tab.active {
  background: var(--primary-soft);
  border-color: var(--primary);
}
.tab-icon {
  font-size: 1.8rem;
  flex-shrink: 0;
}
.tab-txt {
  display: flex;
  flex-direction: column;
}
.tab-txt strong {
  font-size: var(--text-base);
  color: var(--ink);
}
.tab-txt span {
  font-size: var(--text-xs);
  color: var(--muted);
}
.services-panels {
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: var(--r-lg);
  overflow: hidden;
}
.service-panel {
  display: none;
}
.service-panel.active {
  display: block;
}
.panel-content {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  min-height: 380px;
}
.panel-info {
  padding: var(--space-lg);
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.panel-info h3 {
  font-size: var(--text-xl);
  margin-bottom: var(--space-sm);
  color: var(--ink);
}
.panel-desc {
  font-size: var(--text-base);
  color: var(--muted);
  margin-bottom: var(--space-md);
}
.panel-details {
  list-style: none;
}
.panel-details li {
  position: relative;
  padding-left: var(--space-md);
  font-size: var(--text-sm);
  color: var(--ink);
  margin-bottom: 8px;
  line-height: 1.6;
}
.panel-details li::before {
  content: '•';
  position: absolute;
  left: 0;
  color: var(--primary);
  font-weight: 700;
}
.panel-visual {
  overflow: hidden;
  height: 100%;
}
.panel-visual img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ═══════ ITINERARY ═══════ */
.itinerary-section {
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
}
.day-tabs {
  display: flex;
  justify-content: center;
  gap: var(--space-sm);
  margin-block: var(--space-lg) var(--space-xl);
  flex-wrap: wrap;
}
.day-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12px 24px;
  background: var(--bg);
  border: 1px solid var(--line);
  border-radius: var(--r);
  cursor: pointer;
  transition: all 0.25s var(--ease-out);
}
.day-tab:hover {
  border-color: var(--primary);
}
.day-tab.active {
  background: var(--primary);
  border-color: var(--primary);
  color: var(--on-primary);
}
.day-tab strong {
  font-size: var(--text-base);
}
.day-tab span {
  font-size: var(--text-xs);
  opacity: 0.9;
}
.day-tab.active span {
  color: var(--on-primary);
}
.daily-timeline {
  display: none;
  max-width: 700px;
  margin: 0 auto;
}
.daily-timeline.active {
  display: block;
}
.timeline {
  position: relative;
  padding-left: 60px;
}
.timeline-line {
  position: absolute;
  left: 24px;
  top: 0;
  bottom: 0;
  width: 2px;
  background: var(--line-strong);
}
.timeline-item {
  position: relative;
  padding-bottom: var(--space-lg);
  transition-delay: calc(var(--i, 0) * 50ms);
}
.timeline-marker {
  position: absolute;
  left: -60px;
  top: 2px;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 48px;
}
.timeline-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--primary);
  box-shadow: 0 0 0 4px var(--primary-soft);
  z-index: var(--z-raised);
}
.timeline-time {
  font-size: var(--text-xs);
  font-weight: 700;
  color: var(--primary);
  margin-top: 6px;
  font-variant-numeric: tabular-nums;
}
.timeline-content {
  padding-left: var(--space-md);
}
.timeline-title {
  font-size: var(--text-lg);
  font-weight: 700;
  margin-bottom: 4px;
}
.timeline-desc {
  font-size: var(--text-sm);
  color: var(--muted);
  line-height: 1.6;
}
.timeline-img-wrapper {
  margin-top: var(--space-sm);
  border-radius: var(--r);
  overflow: hidden;
  aspect-ratio: 16 / 9;
  max-width: 480px;
  border: 1px solid var(--line);
  box-shadow: var(--shadow-sm);
}
.timeline-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ═══════ FOOTER CTA ═══════ */
.footer-cta-section {
  text-align: center;
  padding-bottom: 120px;
}
.footer-cta-wrap h2 {
  color: white;
  font-size: var(--text-2xl);
  margin-bottom: var(--space-sm);
}
.footer-cta-wrap p {
  color: var(--dark-muted);
  font-size: var(--text-base);
  max-width: 50ch;
  margin: 0 auto var(--space-xl);
}
.cta-actions {
  display: flex;
  gap: var(--space-md);
  justify-content: center;
  flex-wrap: wrap;
}

/* ═══════ STICKY BOOKING BAR ═══════ */
.sticky-booking-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: var(--z-sticky);
  background: oklch(1.000 0.000 0 / 0.95);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow: 0 -2px 12px oklch(0.2 0.01 55 / 0.1);
  padding: 12px var(--space-lg);
  padding-bottom: max(12px, env(safe-area-inset-bottom));
  transform: translateY(0);
  transition: transform 0.4s var(--ease-out);
}
.sticky-booking-inner {
  max-width: var(--maxw);
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.sticky-booking-info h3 {
  font-size: var(--text-sm);
  color: var(--muted);
  font-weight: 500;
}
.sticky-booking-price {
  display: flex;
  align-items: baseline;
  gap: 4px;
}
.sticky-booking-price strong {
  font-size: var(--text-lg);
  color: var(--primary);
  font-weight: 800;
}
.sticky-booking-price span {
  font-size: var(--text-xs);
  color: var(--muted);
}

/* ═══════ RESPONSIVE ═══════ */
@media (max-width: 900px) {
  .services-container {
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }
  .services-tabs {
    flex-direction: row;
    overflow-x: auto;
    padding-bottom: 8px;
    -webkit-overflow-scrolling: touch;
  }
  .service-tab {
    flex: 0 0 160px;
    padding: var(--space-sm);
    flex-direction: column;
    text-align: center;
    gap: var(--space-xs);
  }
  .service-tab:hover {
    transform: none;
  }
  .tab-icon {
    font-size: 1.4rem;
  }
  .tab-txt strong {
    font-size: var(--text-sm);
  }
  .panel-content {
    grid-template-columns: 1fr;
  }
  .panel-visual {
    order: -1;
    height: 220px;
  }
}

@media (max-width: 600px) {
  .detail-hero {
    min-height: 380px;
  }
  .detail-hero h1 {
    font-size: var(--text-2xl);
  }
  .timeline {
    padding-left: 48px;
  }
  .timeline-line {
    left: 18px;
  }
  .timeline-marker {
    left: -48px;
    width: 36px;
  }
}
</style>

<script>
  // Services Tab Switcher
  const tabs = document.querySelectorAll('.service-tab');
  const panels = document.querySelectorAll('.service-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      // Deactivate all tabs & panels
      tabs.forEach(t => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      panels.forEach(p => p.classList.remove('active'));

      // Activate clicked tab & panel
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      const tabName = tab.getAttribute('data-tab');
      const targetPanel = document.getElementById(`panel-${tabName}`);
      targetPanel?.classList.add('active');
    });
  });

  // Day Timeline Switcher
  const dayTabs = document.querySelectorAll('.day-tab');
  const timelines = document.querySelectorAll('.daily-timeline');

  dayTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      // Deactivate all day tabs & timelines
      dayTabs.forEach(t => t.classList.remove('active'));
      timelines.forEach(tl => tl.classList.remove('active'));

      // Activate clicked tab & timeline
      tab.classList.add('active');
      const dayNum = tab.getAttribute('data-day');
      const targetTimeline = document.getElementById(`timeline-day-${dayNum}`);
      targetTimeline?.classList.add('active');

      // Scroll reveal trigger check
      window.dispatchEvent(new Event('scroll'));
    });
  });

  // Simple Scroll Reveal integration on page switch
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  reveals.forEach(el => observer.observe(el));
</script>
