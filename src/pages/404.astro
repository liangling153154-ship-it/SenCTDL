---
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<Base
  title="Không tìm thấy trang — Sen's Homestay (Cao Bằng)"
  description="Trang bạn tìm không tồn tại. Quay về trang chủ để xem các chương trình du lịch Cao Bằng."
>
  <main class="nf-wrap">
    <p class="nf-code">404</p>
    <h1>Lạc đường rồi.</h1>
    <p class="nf-sub">Ở Cao Bằng lạc đường thì có Sen dẫn — còn ở đây thì mời bạn quay về trang chủ.</p>
    <a href={base} class="btn btn-primary nf-btn">Về trang chủ</a>
  </main>
</Base>

<style>
.nf-wrap {
  min-height: 100vh;
  min-height: 100dvh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: var(--space-lg);
  background: var(--surface);
}
.nf-code {
  font-size: var(--text-hero);
  font-weight: 800;
  color: var(--primary-soft);
  line-height: 1;
}
.nf-wrap h1 {
  font-size: var(--text-2xl);
  margin: var(--space-sm) 0;
}
.nf-sub {
  color: var(--muted);
  max-width: 40ch;
  margin-bottom: var(--space-lg);
}
.nf-btn { padding: 14px 28px; }
</style>
