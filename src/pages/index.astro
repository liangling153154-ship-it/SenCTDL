---
import Base from '../layouts/Base.astro';

const ZALO_LINK = 'https://zalo.me/0822946888';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

// Cao Bằng Travel Map (app Leaflet). Local/test: bản copy tạm ở public/map/
// (gitignore). Khi ghép nhánh vào web chính: xoá public/map/, bản đồ thật
// đã sống sẵn ở <web chính>/map/ — đường dẫn này giữ nguyên vẫn đúng.
const MAP_URL = `${base}map/index.html`;

// published: false → chưa phát hành, ẩn khỏi web (bật lại khi có nội dung thật)
const allPrograms = [
  {
    id: '2n1d',
    name: '2 Ngày 1 Đêm',
    tagline: 'Khám phá Cao Bằng hot nhất — tiết kiệm, chủ động',
    price: '2.150.000đ',
    priceNote: '/2 khách',
    highlights: ['Thác Bản Giốc', 'Động Ngườm Ngao', 'Làng đá Khuổi Ky', 'Núi Mắt Thần', 'Hồ Thang Hen', 'Pác Bó'],
    days: 2,
    spots: 6,
    published: true,
    image: 'images/places/ban-gioc.jpg',
  },
  {
    id: '3n2d',
    name: '3 Ngày 2 Đêm',
    tagline: 'Được yêu thích nhất — Đồi Cỏ Cháy, Bản Giốc, Thang Hen, Pác Bó',
    price: '2.850.000đ',
    priceNote: '/2 khách',
    highlights: ['Núi Mắt Thần', 'Đồi Cỏ Cháy', 'Thác Bản Giốc', 'Động Ngườm Ngao', 'Pỉ Pha Viewpoint', 'Hồ Thang Hen', 'Pác Bó'],
    days: 3,
    spots: 10,
    featured: true,
    published: true,
    image: 'images/places/eye-mountain.jpg',
  },
  {
    id: '4n3d',
    name: '4 Ngày 3 Đêm',
    tagline: 'Khám phá sâu — đi chậm, thấy nhiều',
    price: 'Liên hệ',
    priceNote: 'giá tuỳ chỉnh theo nhóm',
    highlights: ['Tất cả điểm 3N2Đ', 'Pác Bó', 'Phja Oắc', 'Cốc Bó suối Lê-nin', 'Đèo Mã Phục', 'Cafe núi'],
    days: 4,
    spots: 14,
    published: false,
    image: 'images/places/khau-coc-cha.jpg',
  },
];
const programs = allPrograms.filter(p => p.published);



const includes = [
  { icon: 'bus', title: 'Vé xe khách', desc: 'Xe giường nằm / cabin VIP Hà Nội ⇆ Cao Bằng khứ hồi' },
  { icon: 'bike', title: 'Xe máy', desc: 'Honda Wave Alpha, đầy xăng, mũ + áo mưa + giá đỡ điện thoại' },
  { icon: 'home', title: 'Sen\'s Homestay', desc: 'Phòng riêng, điều hoà, nóng lạnh, máy chiếu Netflix' },
  { icon: 'map', title: 'Lịch trình tối ưu', desc: 'Cẩm nang chuyến đi (Travel Book) chi tiết từng giờ' },
  { icon: 'phone', title: 'Hotline 24/7', desc: 'Hỗ trợ suốt chuyến đi qua Zalo 0822946888' },
  { icon: 'shield', title: 'Phương án dự phòng', desc: 'Kế hoạch B khi trời mưa cho từng điểm' },
  { icon: 'gift', title: 'Bonus', desc: 'Bản đồ tham quan, gợi ý quán ăn, góc chụp đẹp' },
];

const faqs = [
  { q: 'Giá đã bao gồm những gì?', a: 'Vé xe khách khứ hồi, homestay phòng riêng, xe máy Honda Wave (đầy xăng, mũ, áo mưa, giá đỡ điện thoại), Travel Book và hotline hỗ trợ 24/7. Ăn sáng tại homestay có phụ phí; bữa trưa và tối tự chọn — Travel Book gợi ý quán cụ thể với giá tham khảo.' },
  { q: 'Đi một mình được không?', a: 'Được. Nhiều bạn đi solo hoặc đi cặp. Lịch trình vẫn dễ theo.' },
  { q: 'Không biết đi xe máy thì sao?', a: 'Nhắn Zalo 0822946888. Sen sẽ gợi ý phương án hợp với bạn.' },
  { q: 'Nếu trời mưa thì sao?', a: 'Travel Book có phương án dự phòng cho mỗi hoạt động. Ví dụ: trời mưa ở Bản Giốc → chuyển thời gian xuống chiều, sáng ghé chợ phiên hoặc làng nghề thay thế.' },
  { q: 'Có thể thay đổi lịch trình không?', a: 'Có. Travel Book là gợi ý tối ưu, không phải bắt buộc. Bạn tự do điều chỉnh — hotline luôn sẵn sàng hỗ trợ.' },
  { q: 'Thanh toán như thế nào?', a: 'Chuyển khoản ngân hàng hoặc MoMo. Đặt cọc 50%, thanh toán nốt trước ngày khởi hành 3 ngày.' },
  { q: 'Hủy thì sao?', a: 'Hủy trước 7 ngày: hoàn 100%. Trước 3 ngày: hoàn 70%. Dưới 3 ngày: không hoàn. Sen cần confirm với đối tác.' },
];

// Gallery masonry — trộn khoảnh khắc CHUYẾN ĐI + không gian HOMESTAY,
// xen kẽ ảnh dọc/ngang tạo nhịp. Caption viết theo nội dung THẬT của ảnh.
// Thêm ảnh mới: chỉ cần append vào đây. (gallery-04 = nhà tắm, đã dùng ở
// tab dịch vụ nên không lặp lại ở đây.) item.video = clip tự chạy trong lưới.
const gallery = [
  { src: 'images/gallery-13.jpg', alt: 'Lò rèn truyền thống làng Phúc Sen của người Nùng An' },
  { src: 'images/gallery-22.jpg', alt: 'Hồ Thang Hen và núi Quan Tử nhìn từ mặt nước' },
  { src: 'images/gallery-24.jpg', alt: 'Chân thác Bản Giốc mùa nước đổ' },
  { video: 'videos/gallery-clip.mp4', poster: 'images/gallery-clip-poster.jpg', alt: 'Khoảnh khắc Cao Bằng — clip ngắn từ chuyến đi' },
  { src: 'images/gallery-14.jpg', alt: 'Nhóm bạn check-in trên đồi cỏ xanh Cao Bằng' },
  { src: 'images/gallery-20.jpg', alt: 'Mây mù vờn núi sau cơn mưa chiều' },
  { src: 'images/gallery-16.jpg', alt: 'Núi Mắt Thần soi bóng bên hồ và vó cá' },
  { src: 'images/gallery-25.jpg', alt: 'Con đường uốn lượn qua thung lũng núi đá' },
  { src: 'images/gallery-19.jpg', alt: 'Người dân cưỡi ngựa qua thảo nguyên dưới chân núi Thủng' },
  { src: 'images/gallery-21.jpg', alt: 'Cung đường sương mù trên đường về bản' },
  { src: 'images/gallery-17.jpg', alt: 'Thung lũng đồi cỏ trập trùng như tranh vẽ' },
  { src: 'images/gallery-23.jpg', alt: 'Bến thuyền nhỏ bên hồ xanh ngọc' },
  { src: 'images/gallery-15.jpg', alt: 'Chinh phục đồi cỏ hình chóp — điểm trek yêu thích' },
  { src: 'images/gallery-18.jpg', alt: 'Lặng ngắm núi Mắt Thần giữa buổi sớm' },
  { src: 'images/gallery-26.jpg', alt: 'Đứng trước thác Bản Giốc hùng vĩ' },
  { src: 'images/gallery-27.jpg', alt: 'Làng đá cổ Khuổi Ky nhìn từ trên cao' },
  { src: 'images/gallery-28.jpg', alt: 'Lạc vào rừng trúc xanh mát' },
  { src: 'images/gallery-29.jpg', alt: 'Ruộng bậc thang mùa lúa chín vàng' },
  { src: 'images/gallery-30.jpg', alt: 'Hồ nước xanh ngọc bích giữa rừng già' },
  { src: 'images/gallery-31.jpg', alt: 'Dang tay giữa hoàng hôn trên đồi cỏ' },
];
---

<Base
  title="Du lịch Cao Bằng cùng Sen — khỏi tự lên kế hoạch"
  description="Khỏi tự lên kế hoạch. Chọn combo, nhắn Zalo — xe, phòng, lịch trình, quán ăn: Sen lo hết."
>

<!-- ═══════ NAV ═══════ -->
<nav id="nav">
  <div class="nav-inner">
    <a href={base} class="nav-logo" aria-label="Về trang chủ">
      <svg class="nav-logo-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M12 6v6l4 2"/></svg>
      <span>Sen's Homestay</span>
    </a>
    <div class="nav-links" id="navLinks">
      <a href="#programs">Chuyến đi</a>
      <a href="#map">Bản đồ</a>
      <a href="#includes">Bao gồm</a>
      <a href="#faq">FAQ</a>
      <a href={ZALO_LINK} class="btn btn-zalo nav-cta" target="_blank" rel="noopener">
        <svg class="btn-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12.49 10.272v-.45h1.347v6.322h-.527a.825.825 0 0 1-.82-.826v-.005a3.076 3.076 0 0 1-1.81.582c-1.7 0-3.076-1.418-3.076-3.166s1.376-3.162 3.076-3.162a3.08 3.08 0 0 1 1.81.582v.123zm-1.667 4.727a1.975 1.975 0 0 0 0-3.95 1.975 1.975 0 0 0 0 3.95zM17.56 9.822h1.347v5.571a.825.825 0 0 1-.82.826h-.527V9.822zM18.234 7.5a.875.875 0 1 1 0 1.75.875.875 0 0 1 0-1.75z"/><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm-4.438 12.958a.655.655 0 0 1-.19.014H5.654v-5.15h1.347v3.884h1.42l.015.015c.15.004.518.064.518.518v.184a.55.55 0 0 1-.394.535zm1.027-5.136a.875.875 0 1 1 0-1.75.875.875 0 0 1 0 1.75z"/></svg>
        Nhắn Zalo
      </a>
    </div>
    <button class="nav-hamburger" id="navToggle" aria-label="Mở menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- ═══════ MOBILE MENU ═══════ -->
<div class="mobile-menu" id="mobileMenu" aria-hidden="true">
  <a href="#programs" class="mobile-menu-link">Chuyến đi</a>
  <a href="#map" class="mobile-menu-link">Bản đồ</a>
  <a href="#includes" class="mobile-menu-link">Bao gồm</a>
  <a href="#faq" class="mobile-menu-link">FAQ</a>
  <a href={ZALO_LINK} class="btn btn-zalo mobile-menu-cta" target="_blank" rel="noopener">
    Nhắn Zalo ngay
  </a>
</div>

<!-- ═══════ HERO ═══════ -->
<section id="hero">
  <div class="hero-bg">
    <img
      src={`${base}images/hero/hero-main.jpg`}
      alt="Cảnh núi đá vôi và ruộng bậc thang ở Cao Bằng, Việt Nam"
      class="hero-photo desktop-only"
      loading="eager"
      fetchpriority="high"
    />
    <video
      autoplay
      loop
      muted
      playsinline
      class="hero-video mobile-only"
    >
      <source src={`${base}images/hero/hero.mp4`} type="video/mp4" />
    </video>
    <div class="hero-overlay"></div>
    <div class="hero-fade"></div>
  </div>
  <div class="wrap hero-content">
    <p class="hero-place reveal">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      Cao Bằng, Việt Nam
    </p>
    <h1 class="reveal reveal-delay-1">
      Cao Bằng đã có<br/>
      <span class="hero-accent">Sen lên lịch.</span>
    </h1>
    <p class="hero-sub reveal reveal-delay-2">
      Khỏi lên kế hoạch. Chọn combo, xách balo đi — xe, phòng, lịch trình, quán ăn: Sen lo hết.
    </p>
    <div class="hero-btns reveal reveal-delay-3">
      <a href={ZALO_LINK} class="btn btn-primary" target="_blank" rel="noopener">
        Nhắn Zalo — Đặt lịch
      </a>
      <a href="#programs" class="btn btn-outline hero-btn-outline">
        Xem chuyến đi
      </a>
    </div>
  </div>
  <div class="hero-scroll" aria-hidden="true">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
  </div>
</section>

<!-- ═══════ PROBLEM ═══════ -->
<section id="problem" class="section-pad">
  <div class="wrap">
    <div class="problem-layout">
      <div class="problem-left reveal">
        <h2>Tự đi Cao Bằng?<br/>Bạn phải quyết định<br/><span class="text-accent">15 thứ.</span></h2>
      </div>
      <div class="problem-right">
        <ul class="problem-list">
          {['Đi xe nào?', 'Mấy giờ xuất phát?', 'Thuê xe ở đâu?', 'Đi điểm nào trước?', 'Có kịp không?', 'Ăn sáng ở đâu?', 'Ăn trưa ở đâu?', 'Cafe ở đâu?', 'Đường nào đẹp?', 'Mấy giờ check-in?', 'Cần đặt vé trước?', 'Điểm nào đáng đi?'].map((item, i) => (
            <li class="problem-item reveal" style={`--i: ${i}`}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
              {item}
            </li>
          ))}
        </ul>
        <div class="problem-answer reveal">
          <div class="problem-answer-line"></div>
          <p class="problem-answer-text">
            <strong>Sen đã gỡ hết.</strong><br/>
            Bạn chọn combo. Phần còn lại để Sen lo.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════ TRAVEL MAP ═══════ -->
<section id="map" class="section-pad">
  <div class="wrap">
    <a href={MAP_URL} class="map-panel reveal" aria-label="Mở bản đồ Cao Bằng tương tác">
      <img src={`${base}images/map_hero.jpg`} alt="Bản đồ Cao Bằng ghim tay các điểm: Bản Giốc, Ngườm Ngao, Núi Mắt Thần, Ba Quang" loading="lazy" />
      <div class="map-scrim"></div>
      <span class="map-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M9 4 4 6v14l5-2 6 2 5-2V4l-5 2-6-2z"/><path d="M9 4v14M15 6v14"/></svg>
        Bản đồ
      </span>
      <div class="map-overlay">
        <span class="map-flag">Tương tác · Người bản địa vẽ tay</span>
        <h2>Bản đồ Cao Bằng<br/>của riêng Sen</h2>
        <p>45 điểm được Sen ghim tay — từng con thác, hang động, quán cà phê và cung đường thật sự đáng đi. Kèm 3 lộ trình vẽ sẵn với khoảng cách &amp; thời gian chạy thực tế.</p>
        <div class="map-foot">
          <div class="map-tags">
            <span class="map-pin">Thác Bản Giốc</span>
            <span class="map-pin">Núi Mắt Thần</span>
            <span class="map-pin">Ngườm Ngao</span>
            <span class="map-pin">Ba Quang</span>
          </div>
          <span class="map-open btn btn-primary">
            Mở bản đồ
            <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </div>
      </div>
    </a>
  </div>
</section>

<!-- ═══════ PROGRAMS ═══════ -->
<section id="programs" class="section-pad bg-surface">
  <div class="wrap">
    <div class="section-header reveal">
      <h2>Chọn chuyến đi<br/>hợp với bạn</h2>
      <p class="section-sub">Mỗi combo đã có đủ xe, phòng, lịch trình và quán ăn. Bạn chỉ cần xách balo lên.</p>
    </div>
    <div class="programs-grid">
      {programs.map((p, i) => (
        <a href={`${base}programs/${p.id}/`} class={`program-card reveal ${p.featured ? 'program-featured' : ''}`} style={`--i: ${i}`}>
          {p.featured && <div class="program-badge">Được chọn nhiều nhất</div>}
          <div class="program-img-wrapper">
            <img src={p.image} alt={p.name} class="program-img" loading="lazy" />
          </div>
          <div class="program-card-body">
            <div class="program-header">
              <h3 class="program-name">{p.name}</h3>
              <p class="program-tagline">{p.tagline}</p>
            </div>
            <div class="program-price">
              <span class="program-price-amount">{p.price}</span>
              <span class="program-price-note">{p.priceNote}</span>
            </div>
            <div class="program-meta">
              <span class="program-meta-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                {p.days} ngày
              </span>
              <span class="program-meta-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {p.spots} điểm đến
              </span>
            </div>
            <ul class="program-highlights">
              {p.highlights.map(h => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                  {h}
                </li>
              ))}
            </ul>
            <span class={`btn ${p.featured ? 'btn-primary' : 'btn-outline'} program-cta`}>
              Xem chi tiết lịch trình
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ═══════ INCLUDES ═══════ -->
<section id="includes" class="section-pad bg-surface">
  <div class="wrap">
    <div class="section-header reveal">
      <h2>Đã bao gồm<br/>trong chuyến đi</h2>
      <p class="section-sub">Bạn không cần tự đặt từng thứ. Sen chuẩn bị sẵn.</p>
    </div>
    <div class="includes-grid">
      {includes.map((item, i) => (
        <div class="include-item reveal" style={`--i: ${i}`}>
          <div class="include-icon">
            {item.icon === 'bus' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 6v6M16 6v6M2 12h20M6 18h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2zM6 18v2M18 18v2"/></svg>}
            {item.icon === 'bike' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18.5" cy="17.5" r="3.5"/><circle cx="5.5" cy="17.5" r="3.5"/><path d="M15 6a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm-3 11.5V14l-3-3 4-3 2 3h2"/></svg>}
            {item.icon === 'home' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>}
            {item.icon === 'utensils' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2M7 2v20M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/></svg>}
            {item.icon === 'map' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>}
            {item.icon === 'phone' && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>}
