<style>
/* ═══════ NAV ═══════ */
nav {
  position: fixed;
  inset: 0 0 auto 0;
  z-index: var(--z-sticky);
  background: transparent;
  transition: background 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out);
}
nav.scrolled {
  background: oklch(1.000 0.000 0 / 0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  box-shadow: 0 1px 0 var(--line);
}
.nav-inner {
  max-width: var(--maxw);
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72px;
  padding-inline: var(--space-lg);
}
.nav-logo {
  display: flex;
  align-items: center;
  gap: 8px;
  font-weight: 800;
  font-size: 1.15rem;
  letter-spacing: -0.02em;
  color: white;
  transition: color 0.3s;
}
nav.scrolled .nav-logo { color: var(--ink); }
.nav-logo-icon {
  width: 24px;
  height: 24px;
  color: var(--primary-soft);
  transition: color 0.3s;
}
nav.scrolled .nav-logo-icon { color: var(--primary); }
.nav-links {
  display: flex;
  align-items: center;
  gap: 28px;
}
.nav-links a:not(.nav-cta) {
  font-size: var(--text-sm);
  font-weight: 600;
  color: white;
  opacity: 0.9;
  transition: opacity 0.2s, color 0.3s;
}
nav.scrolled .nav-links a:not(.nav-cta) {
  color: var(--muted);
  opacity: 1;
}
.nav-links a:not(.nav-cta):hover { opacity: 1; }
nav.scrolled .nav-links a:not(.nav-cta):hover { color: var(--ink); }
.nav-cta {
  padding: 10px 20px;
  font-size: var(--text-sm);
}
.nav-hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  cursor: pointer;
  padding: 8px;
}
.nav-hamburger span {
  width: 22px;
  height: 2px;
  background: white;
  border-radius: 2px;
  transition: background 0.3s, transform 0.3s;
}
nav.scrolled .nav-hamburger span { background: var(--ink); }

/* ═══════ MOBILE MENU ═══════ */
.mobile-menu {
  position: fixed;
  inset: 72px 0 0 0;
  z-index: calc(var(--z-sticky) - 1);
  background: var(--bg);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: var(--space-xl) var(--space-lg);
  transform: translateY(-100%);
  opacity: 0;
  pointer-events: none;
  transition: transform 0.4s var(--ease-out), opacity 0.3s;
}
.mobile-menu.open {
  transform: translateY(0);
  opacity: 1;
  pointer-events: auto;
}
.mobile-menu-link {
  font-size: var(--text-lg);
  font-weight: 600;
  padding: 12px 0;
  color: var(--ink);
}
.mobile-menu-cta { margin-top: var(--space-md); width: 100%; text-align: center; }

/* ═══════ HERO ═══════ */
#hero {
  position: relative;
  min-height: 100vh;
  min-height: 100dvh;
  display: flex;
  align-items: flex-end;
  padding: 0 0 var(--space-hero);
  overflow: hidden;
}
.hero-bg {
  position: absolute;
  inset: 0;
}
.hero-photo, .hero-video {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.hero-photo {
  transform: scale(1.05);
  transition: transform 12s var(--ease-out);
}
.hero-photo.loaded { transform: scale(1); }

/* Responsive display logic */
.hero-video.mobile-only {
  display: none;
}
.hero-photo.desktop-only {
  display: block;
}

@media (max-width: 768px) {
  .hero-video.mobile-only {
    display: block;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-photo.desktop-only {
    display: none;
  }
}
.hero-overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, oklch(0.12 0.01 55 / 0.45) 0%, oklch(0.12 0.01 55 / 0.08) 30%, transparent 55%, oklch(0.12 0.01 55 / 0.25) 80%, oklch(0.12 0.01 55 / 0.50) 100%),
    linear-gradient(90deg, oklch(0.12 0.01 55 / 0.55) 0%, oklch(0.12 0.01 55 / 0.15) 50%, transparent 100%);
}
.hero-fade {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  height: 14%;
  background: linear-gradient(180deg, transparent 0%, oklch(1.000 0.000 0 / 0.6) 60%, var(--bg) 100%);
  z-index: 1;
  pointer-events: none;
}
.hero-content {
  position: relative;
  z-index: var(--z-raised);
  color: white;
  max-width: 700px;
}
.hero-place {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-weight: 600;
  font-size: var(--text-sm);
  letter-spacing: 0.04em;
  margin-bottom: var(--space-md);
  text-shadow: 0 1px 6px oklch(0.1 0.02 55 / 0.7);
}
.hero-place svg { color: var(--primary-soft); }
#hero h1 {
  color: white;
  font-size: var(--text-hero);
  font-weight: 800;
  line-height: 1.0;
  letter-spacing: -0.03em;
  margin-bottom: var(--space-lg);
  text-shadow: 0 2px 8px oklch(0.1 0.02 55 / 0.5), 0 6px 24px oklch(0.1 0.02 55 / 0.4);
}
.hero-accent {
  color: oklch(0.85 0.10 55);
}
.hero-sub {
  font-size: var(--text-lg);
  font-weight: 500;
  color: oklch(0.92 0.01 55);
  max-width: 540px;
  margin-bottom: var(--space-xl);
  text-shadow: 0 1px 4px oklch(0.1 0.02 55 / 0.6);
}
.hero-btns {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}
/* Over-photo: nền tối đặc + viền trắng rõ (theo DESIGN.md §7 dark-solid badge) */
.hero-btn-outline {
  background: rgba(20, 15, 10, 0.55);
  box-shadow: inset 0 0 0 1.5px oklch(1 0 0 / 0.7);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  color: white;
}
.hero-btn-outline:hover {
  background: rgba(20, 15, 10, 0.7);
  box-shadow: inset 0 0 0 1.5px oklch(1 0 0 / 0.9);
  color: white;
}
.hero-scroll {
  position: absolute;
  bottom: var(--space-lg);
  left: 50%;
  transform: translateX(-50%);
  z-index: var(--z-raised);
  color: oklch(0.2 0.01 55 / 0.5);
  animation: nudge 2.4s var(--ease-out) infinite;
}
@keyframes nudge {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(8px); }
}

/* ═══════ SECTION HEADERS ═══════ */
.section-header {
  max-width: 640px;
  margin-bottom: var(--space-xl);
}
.section-header h2 {
  font-size: var(--text-3xl);
  margin-bottom: var(--space-sm);
}
.section-sub {
  color: var(--muted);
  font-size: var(--text-lg);
}
.bg-surface { background: var(--surface); }
.bg-dark {
  background: var(--dark-bg);
  color: var(--dark-text);
}
.bg-dark h2 { color: white; }
.bg-dark .section-sub { color: var(--dark-muted); }

/* ═══════ PROBLEM ═══════ */
.problem-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-2xl);
  align-items: start;
}
.problem-left h2 {
  font-size: var(--text-3xl);
  line-height: 1.15;
}
.text-accent { color: var(--primary); }
.text-accent-light { color: oklch(0.78 0.10 55); }
.problem-list {
  list-style: none;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}
.problem-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--muted);
  background: var(--surface);
  border-radius: var(--r-sm);
  border: 1px solid var(--line);
  transition-delay: calc(var(--i, 0) * 40ms);
}
.problem-item svg { color: var(--primary); flex-shrink: 0; }
.problem-answer {
  margin-top: var(--space-lg);
  padding: var(--space-lg);
  background: var(--primary-soft);
  border-radius: var(--r);
  position: relative;
}
.problem-answer-line {
  position: absolute;
  top: calc(-1 * var(--space-lg));
  left: 50%;
  width: 2px;
  height: var(--space-lg);
  background: var(--primary);
}
.problem-answer-text {
  font-size: var(--text-base);
  color: var(--ink);
}
.problem-answer-text strong { color: var(--primary-hover); }

/* ═══════ TRAVEL MAP (panel theo pattern web chính) ═══════ */
.map-panel {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  position: relative;
  min-height: 520px;
  border-radius: var(--r);
  overflow: hidden;
  box-shadow: var(--shadow);
  transition: transform 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out);
}
.map-panel:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}
.map-panel > img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s var(--ease-out);
}
.map-panel:hover > img { transform: scale(1.03); }
/* Scrim: tối chủ yếu sau chữ (dưới/trái), phần còn lại giữ sáng — DESIGN.md §7 */
.map-scrim {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(24,20,14,0.18) 0%, rgba(24,20,14,0) 35%, rgba(24,20,14,0.72) 100%),
    linear-gradient(90deg, rgba(24,20,14,0.35) 0%, rgba(24,20,14,0.05) 55%, transparent 100%);
}
/* Badge góc: dark-solid trên ảnh */
.map-badge {
  position: absolute;
  top: 16px;
  right: 16px;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  background: rgba(20, 15, 10, 0.72);
  border: 1px solid rgba(246, 239, 226, 0.22);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  color: var(--dark-text);
  font-size: var(--text-xs);
  font-weight: 700;
  padding: 7px 13px;
  border-radius: var(--r-pill);
}
.map-badge svg { width: 15px; height: 15px; }
.map-overlay {
  position: relative;
  z-index: var(--z-base);
  padding: var(--space-xl);
  max-width: 640px;
}
.map-flag {
  display: inline-block;
  color: #F2C28E;
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.02em;
  margin-bottom: 10px;
  text-shadow: 0 1px 3px rgba(16, 12, 6, 0.6);
}
.map-overlay h2 {
  color: #fff;
  font-size: clamp(1.9rem, 3.6vw, 2.8rem);
  margin-bottom: 12px;
  paint-order: stroke fill;
  -webkit-text-stroke: 1px rgba(16, 12, 6, 0.45);
  text-shadow: 0 1px 2px rgba(16,12,6,0.6), 0 2px 8px rgba(16,12,6,0.5);
}
.map-overlay p {
  color: rgba(255, 255, 255, 0.94);
  font-size: var(--text-base);
  max-width: 56ch;
  margin-bottom: var(--space-md);
  text-shadow: 0 1px 3px rgba(16, 12, 6, 0.55);
}
.map-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  flex-wrap: wrap;
}
.map-tags {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}
.map-pin {
  display: inline-flex;
  align-items: center;
  background: rgba(20, 15, 10, 0.55);
  border: 1px solid rgba(246, 239, 226, 0.25);
  backdrop-filter: blur(3px);
  -webkit-backdrop-filter: blur(3px);
  color: var(--dark-text);
  font-size: var(--text-xs);
  font-weight: 600;
  padding: 6px 12px;
  border-radius: var(--r-pill);
}
.map-open { flex-shrink: 0; }

@media (max-width: 768px) {
  .map-panel { min-height: 560px; }
  /* Mobile: cột chữ cao hơn → scrim dọc phải đậm sớm hơn để chữ nổi trên nền giấy sáng */
  .map-scrim {
    background:
      linear-gradient(180deg, rgba(24,20,14,0.22) 0%, rgba(24,20,14,0.5) 38%, rgba(24,20,14,0.84) 100%);
  }
  .map-overlay { padding: var(--space-lg); }
  .map-foot { flex-direction: column; align-items: stretch; }
  .map-open { width: 100%; }
  /* Mobile: giữ 2 pin đầu cho gọn màn hình hẹp */
  .map-pin:nth-child(n+3) { display: none; }
}

/* ═══════ PROGRAMS ═══════ */
.programs-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-md);
}
.program-card {
  color: inherit;
  text-decoration: none;
  background: var(--bg);
  border: 1px solid var(--line);
  border-radius: var(--r-lg);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transition: transform 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out);
  position: relative;
  transition-delay: calc(var(--i, 0) * 80ms);
}
.program-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}
.program-img-wrapper {
  position: relative;
  width: 100%;
  height: 200px;
  overflow: hidden;
}
.program-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s var(--ease-out);
}
.program-card:hover .program-img {
  transform: scale(1.05);
}
.program-card-body {
  padding: var(--space-lg);
  display: flex;
  flex-direction: column;
  flex: 1;
}
.program-featured {
  border-color: var(--primary);
  box-shadow: var(--shadow);
}
.program-badge {
  position: absolute;
  top: -12px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--primary);
  color: var(--on-primary);
  font-size: var(--text-xs);
  font-weight: 700;
  padding: 6px 16px;
  border-radius: var(--r-pill);
  white-space: nowrap;
}
.program-header { margin-bottom: var(--space-md); }
.program-name {
  font-size: var(--text-xl);
  margin-bottom: 4px;
}
.program-tagline {
  color: var(--muted);
  font-size: var(--text-sm);
}
.program-price {
  margin-bottom: var(--space-md);
  padding-bottom: var(--space-md);
  border-bottom: 1px solid var(--line);
}
.program-price-amount {
  font-size: var(--text-2xl);
  font-weight: 800;
  color: var(--primary);
}
.program-price-note {
  font-size: var(--text-sm);
  color: var(--muted);
  margin-left: 4px;
}
.program-meta {
  display: flex;
  gap: var(--space-md);
  margin-bottom: var(--space-md);
}
.program-meta-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--muted);
}
.program-meta-item svg { color: var(--accent); }
.program-highlights {
  list-style: none;
  flex: 1;
  margin-bottom: var(--space-lg);
}
.program-highlights li {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 0;
  font-size: var(--text-sm);
  color: var(--ink);
}
.program-highlights svg { color: var(--accent); flex-shrink: 0; }
.program-cta { width: 100%; text-align: center; }

/* ═══════ TIMELINE ═══════ */
.timeline {
  position: relative;
  max-width: 700px;
  margin: 0 auto;
  padding-left: 60px;
}
.timeline-line {
  position: absolute;
  left: 24px;
  top: 0;
  bottom: 0;
  width: 2px;
  background: var(--line);
}
.timeline-item {
  position: relative;
  padding-bottom: var(--space-lg);
  transition-delay: calc(var(--i, 0) * 60ms);
}
.timeline-marker {
  position: absolute;
  left: -60px;
  top: 2px;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 48px;
}
.timeline-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--primary);
  box-shadow: 0 0 0 4px var(--primary-soft);
  z-index: var(--z-raised);
}
.timeline-time {
  font-size: var(--text-xs);
  font-weight: 700;
  color: var(--primary);
  margin-top: 6px;
  font-variant-numeric: tabular-nums;
}
.timeline-content {
  padding-left: var(--space-md);
}
.timeline-title {
  font-size: var(--text-lg);
  font-weight: 700;
  margin-bottom: 4px;
}
.timeline-desc {
  font-size: var(--text-sm);
  color: var(--muted);
  line-height: 1.6;
}
.timeline-img-wrapper {
  margin-top: var(--space-sm);
  border-radius: var(--r);
  overflow: hidden;
  aspect-ratio: 16 / 9;
  max-width: 480px;
  border: 1px solid var(--line);
  box-shadow: var(--shadow-sm);
}
.timeline-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.timeline-cta {
  text-align: center;
  margin-top: var(--space-xl);
  padding-top: var(--space-xl);
  border-top: 1px solid var(--line);
}
.timeline-cta p {
  margin: 0 auto var(--space-md);
  color: var(--muted);
  max-width: 50ch;
}
.timeline-cta strong { color: var(--ink); }

/* ═══════ INCLUDES ═══════ */
.includes-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: var(--space-md);
}
.include-item {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: var(--space-lg);
  background: var(--bg);
  border-radius: var(--r);
  border: 1px solid var(--line);
  transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
  transition-delay: calc(var(--i, 0) * 50ms);
}
.include-item:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-sm);
}
.include-icon {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--r-sm);
  background: var(--primary-soft);
  color: var(--primary);
}
.include-icon svg { width: 22px; height: 22px; }
.include-title {
  font-size: var(--text-base);
  font-weight: 700;
}
.include-desc {
  font-size: var(--text-sm);
  color: var(--muted);
  line-height: 1.5;
}

/* ═══════ TRAVEL BOOK ═══════ */
.travelbook-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-2xl);
  align-items: center;
}
.travelbook-text h2 { color: white; font-size: var(--text-3xl); margin-bottom: var(--space-md); }
.travelbook-sub {
  color: var(--dark-muted);
  font-size: var(--text-lg);
  margin-bottom: var(--space-lg);
}
.travelbook-list {
  list-style: none;
  margin-bottom: var(--space-xl);
}
.travelbook-list li {
  padding: 8px 0;
  font-size: var(--text-base);
  color: var(--dark-text);
  display: flex;
  align-items: center;
  gap: 10px;
}
.travelbook-list li::before {
  content: '✓';
  color: var(--primary);
  font-weight: 700;
  flex-shrink: 0;
}
.travelbook-mockup {
  background: oklch(0.22 0.015 55);
  border-radius: var(--r-lg);
  overflow: hidden;
  box-shadow: var(--shadow-lg);
}
.travelbook-mockup-header {
  display: flex;
  gap: 6px;
  padding: 12px 16px;
  background: oklch(0.18 0.012 55);
}
.travelbook-mockup-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: oklch(0.35 0.01 55);
}
.travelbook-mockup-content {
  padding: 20px;
}
.travelbook-mockup-title {
  font-weight: 700;
  font-size: var(--text-base);
  color: white;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid oklch(0.30 0.01 55);
}
.travelbook-mockup-row {
  display: flex;
  gap: 16px;
  padding: 8px 12px;
  border-radius: 6px;
  margin-bottom: 4px;
}
.travelbook-mockup-row.highlighted {
  background: oklch(0.540 0.130 55 / 0.15);
}
.travelbook-mockup-time {
  font-size: var(--text-sm);
  font-weight: 700;
  color: var(--primary);
  font-variant-numeric: tabular-nums;
  width: 48px;
  flex-shrink: 0;
}
.travelbook-mockup-event {
  font-size: var(--text-sm);
  color: var(--dark-text);
}
.travelbook-mockup-note {
  font-size: var(--text-xs);
  color: var(--dark-muted);
  padding: 4px 12px 8px 76px;
  font-style: italic;
}
.travelbook-mockup-more {
  text-align: center;
  font-size: var(--text-sm);
  color: var(--dark-muted);
  padding-top: 12px;
  border-top: 1px solid oklch(0.30 0.01 55);
  margin-top: 8px;
}

/* ═══════ GALLERY ═══════ */
/* Masonry kiểu Pinterest: ảnh giữ tỷ lệ gốc (dọc/ngang xen kẽ),
   fade-in 1s khi cuộn tới — port từ mẫu React ImageGallery sang CSS thuần */
.gallery-grid {
  columns: 3;
  column-gap: var(--space-md);
}
.gallery-item {
  position: relative;
  display: block;
  width: 100%;
  margin-bottom: var(--space-md);
  break-inside: avoid;
  border-radius: var(--r-lg);
  overflow: hidden;
  border: 1px solid var(--line);
  background: var(--surface-raised); /* placeholder khi ảnh chưa tải */
  padding: 0;
  cursor: zoom-in;
  text-align: left;
  transition: opacity 1s ease-in-out, transform 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out);
  transition-delay: calc(var(--i, 0) * 60ms);
}
/* Reveal của gallery = fade thuần như mẫu (không trượt dọc) */
.gallery-item.reveal { transform: none; }
.gallery-item.reveal.visible { transform: none; }
/* Item video: clip tự chạy trong lưới, không zoom lightbox */
.gallery-video { cursor: default; }

/* ── Lightbox ── */
.lightbox {
  border: none;
  padding: 0;
  background: transparent;
  max-width: min(92vw, 1100px);
  max-height: 90vh;
}
.lightbox::backdrop {
  background: oklch(0.1 0.01 55 / 0.85);
  backdrop-filter: blur(4px);
}
.lightbox img {
  width: 100%;
  max-height: 78vh;
  object-fit: contain;
  border-radius: var(--r);
}
.lightbox-caption {
  color: white;
  text-align: center;
  font-size: var(--text-sm);
  margin-top: 10px;
}
.lightbox-close {
  position: absolute;
  top: -4px;
  right: 0;
  transform: translateY(-100%);
  color: white;
  font-size: 1.2rem;
  padding: 8px;
  background: none;
}
.gallery-item:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
  transition-delay: 0s; /* hover phản hồi ngay, không ăn delay stagger */
}
.gallery-img {
  display: block;
  width: 100%;
  height: auto; /* giữ tỷ lệ gốc của ảnh — tạo nhịp masonry */
  max-height: 480px; /* chặn ảnh dọc quá cao làm lệch cân bằng cột */
  object-fit: cover;
  transition: transform 0.6s var(--ease-out);
}
.gallery-item:hover .gallery-img {
  transform: scale(1.05);
}
.gallery-caption {
  position: absolute;
  inset: auto 0 0 0;
  padding: var(--space-md) var(--space-lg);
  background: linear-gradient(180deg, transparent 0%, oklch(0.12 0.015 55 / 0.8) 100%);
  color: white;
  font-weight: 600;
  font-size: var(--text-sm);
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 0.3s var(--ease-out), transform 0.3s var(--ease-out);
}
.gallery-item:hover .gallery-caption {
  opacity: 1;
  transform: translateY(0);
}
@media (max-width: 900px) {
  .gallery-grid { columns: 2; }
}
@media (max-width: 600px) {
  /* Mobile giữ 2 cột masonry — dày ảnh kiểu Pinterest */
  .gallery-grid { columns: 2; column-gap: 10px; }
  .gallery-item { margin-bottom: 10px; }
  .gallery-caption { padding: var(--space-sm); font-size: var(--text-xs); }
}

/* ═══════ TRUST ═══════ */
.trust-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-2xl);
  align-items: center;
}
.trust-statement h2 {
  font-size: var(--text-3xl);
  margin-bottom: var(--space-md);
}
.trust-desc {
  color: var(--muted);
  font-size: var(--text-base);
  line-height: 1.7;
}
.trust-quote {
  margin-top: var(--space-lg);
  font-family: 'Source Serif 4', Georgia, serif;
  font-style: italic;
  font-size: var(--text-lg);
  line-height: 1.6;
  color: var(--ink);
  max-width: 46ch;
}
.trust-quote em { color: var(--primary-hover); font-style: italic; }
.trust-photo {
  margin: 0;
  border-radius: var(--r-lg);
  overflow: hidden;
  box-shadow: var(--shadow);
}
.trust-photo img {
  width: 100%;
  aspect-ratio: 4 / 3;
  object-fit: cover;
}
.trust-photo figcaption {
  padding: var(--space-sm) var(--space-md);
  font-size: var(--text-sm);
  color: var(--muted);
  background: var(--surface);
}

/* ═══════ FAQ ═══════ */
.faq-list {
  max-width: 740px;
  margin: 0 auto;
}
.faq-item {
  border-bottom: 1px solid var(--line);
  transition-delay: calc(var(--i, 0) * 40ms);
}
.faq-question {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-lg) 0;
  font-size: var(--text-lg);
  font-weight: 600;
  cursor: pointer;
  list-style: none;
  color: var(--ink);
}
.faq-question::-webkit-details-marker { display: none; }
.faq-question::marker { display: none; content: ''; }
.faq-chevron {
  flex-shrink: 0;
  transition: transform 0.3s var(--ease-out);
  color: var(--muted);
}
.faq-item[open] .faq-chevron { transform: rotate(180deg); }
.faq-answer {
  padding-bottom: var(--space-lg);
}
.faq-answer p {
  color: var(--muted);
  font-size: var(--text-base);
  line-height: 1.7;
}

/* ═══════ FINAL CTA ═══════ */
#cta {
  position: relative;
  overflow: hidden;
}
.cta-bg {
  position: absolute;
  inset: 0;
}
.cta-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.cta-bg-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, oklch(0.16 0.02 55 / 0.35) 0%, oklch(0.16 0.02 55 / 0.62) 100%);
}
.cta-wrap { text-align: center; position: relative; z-index: var(--z-raised); }
#cta .cta-sub { color: oklch(0.93 0.01 55); text-shadow: 0 1px 4px oklch(0.1 0.02 55 / 0.5); }
#cta h2 { text-shadow: 0 2px 8px oklch(0.1 0.02 55 / 0.5); }
.cta-content h2 {
  color: white;
  font-size: var(--text-3xl);
  margin-bottom: var(--space-md);
}
.cta-sub {
  color: var(--dark-muted);
  font-size: var(--text-lg);
  max-width: 50ch;
  margin: 0 auto var(--space-xl);
}
.btn-lg {
  padding: 20px 40px;
  font-size: var(--text-lg);
}
.cta-call {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-top: var(--space-md);
  margin-left: var(--space-md);
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--dark-text);
  opacity: 0.9;
  transition: opacity 0.2s;
}
.cta-call:hover { opacity: 1; color: white; }
.cta-note {
  margin-top: var(--space-md);
  font-size: var(--text-sm);
  color: var(--dark-muted);
}

/* ═══════ FOOTER ═══════ */
.footer {
  background: oklch(0.12 0.015 55);
  padding: var(--space-xl) 0;
}
.footer-inner {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-lg);
}
.footer-brand { flex: 1; min-width: 200px; }
.footer-logo {
  font-weight: 800;
  font-size: var(--text-lg);
  color: white;
}
.footer-tagline {
  color: var(--dark-muted);
  font-size: var(--text-sm);
  margin-top: 4px;
}
.footer-links {
  display: flex;
  gap: var(--space-lg);
}
.footer-links a {
  color: var(--dark-muted);
  font-size: var(--text-sm);
  font-weight: 500;
  transition: color 0.2s;
}
.footer-links a:hover { color: white; }
.footer-contact {
  display: flex;
  gap: var(--space-md);
}
.footer-contact a {
  color: var(--primary);
  font-size: var(--text-sm);
  font-weight: 600;
  transition: opacity 0.2s;
}
.footer-contact a:hover { opacity: 0.8; }
.footer-copy {
  width: 100%;
  text-align: center;
  color: oklch(0.40 0.005 55);
  font-size: var(--text-xs);
  margin-top: var(--space-md);
  padding-top: var(--space-md);
  border-top: 1px solid oklch(0.22 0.01 55);
}

/* ═══════ STICKY CTA (mobile) ═══════ */
.sticky-cta {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: var(--z-sticky);
  padding: 12px var(--space-lg);
  padding-bottom: max(12px, env(safe-area-inset-bottom));
  background: oklch(1 0 0 / 0.95);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow: 0 -2px 12px oklch(0.2 0.01 55 / 0.1);
  display: none;
  transform: translateY(100%);
  transition: transform 0.4s var(--ease-out);
}
.sticky-cta.visible { transform: translateY(0); }
.sticky-cta-btn { flex: 1; text-align: center; }
.sticky-call-btn {
  flex-shrink: 0;
  width: 48px;
  height: 48px;
  padding: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--surface);
  border: 1px solid var(--line-strong);
  color: var(--primary);
}

/* ═══════ RESPONSIVE ═══════ */
@media (max-width: 900px) {
  .programs-grid { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto; }
  .problem-layout { grid-template-columns: 1fr; gap: var(--space-xl); }
  .travelbook-layout { grid-template-columns: 1fr; }
  .trust-layout { grid-template-columns: 1fr; }
}

@media (max-width: 768px) {
  .nav-links { display: none; }
  .nav-hamburger { display: flex; }
  .sticky-cta { display: flex; gap: 10px; align-items: center; }

  #hero { min-height: 85vh; min-height: 85dvh; padding-bottom: var(--space-2xl); }
  #hero h1 { font-size: clamp(2.2rem, 8vw, 3.4rem); }

  /* Giữ 2 cột + chip gọn để không kéo dài scroll trên mobile */
  .problem-list { grid-template-columns: 1fr 1fr; gap: 6px; }
  .problem-item { padding: 8px 10px; font-size: var(--text-xs); gap: 6px; }
  .problem-item svg { display: none; }

  .timeline { padding-left: 48px; }
  .timeline-line { left: 18px; }
  .timeline-marker { left: -48px; width: 36px; }
  .timeline-time { font-size: 0.65rem; }

  .footer-inner { flex-direction: column; align-items: flex-start; }
  .footer-links { flex-wrap: wrap; }

  /* Bottom padding for sticky CTA */
  .footer { padding-bottom: 80px; }

  .hero-scroll { display: none; }
}

@media (prefers-reduced-motion: reduce) {
  .hero-photo { transform: none; transition: none; }
  .hero-scroll { animation: none; }
  * { scroll-behavior: auto !important; }
}
</style>

<script>
  // Nav scroll state
  const nav = document.getElementById('nav');
  const handleScroll = () => {
    nav?.classList.toggle('scrolled', window.scrollY > 60);
  };
  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();

  // Hero image load animation
  const heroPhoto = document.querySelector('.hero-photo') as HTMLImageElement;
  if (heroPhoto) {
    if (heroPhoto.complete) {
      heroPhoto.classList.add('loaded');
    } else {
      heroPhoto.addEventListener('load', () => heroPhoto.classList.add('loaded'));
    }
  }

  // Mobile menu toggle
  const navToggle = document.getElementById('navToggle');
  const mobileMenu = document.getElementById('mobileMenu');
  navToggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('open');
    navToggle.setAttribute('aria-expanded', String(isOpen));
    mobileMenu?.setAttribute('aria-hidden', String(!isOpen));
  });
  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.remove('open');
      navToggle?.setAttribute('aria-expanded', 'false');
      mobileMenu.setAttribute('aria-hidden', 'true');
    });
  });

  // Scroll reveal with IntersectionObserver
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  reveals.forEach(el => observer.observe(el));

  // Gallery lightbox
  const lightbox = document.getElementById('lightbox') as HTMLDialogElement;
  const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement;
  const lightboxCaption = document.getElementById('lightboxCaption');
  document.querySelectorAll<HTMLElement>('.gallery-item').forEach(item => {
    item.addEventListener('click', () => {
      if (!lightbox || !lightboxImg) return;
      if (!item.dataset.full) return; // item video: không mở lightbox
      lightboxImg.src = item.dataset.full || '';
      lightboxImg.alt = item.dataset.alt || '';
      if (lightboxCaption) lightboxCaption.textContent = item.dataset.alt || '';
      lightbox.showModal();
    });
  });
  document.getElementById('lightboxClose')?.addEventListener('click', () => lightbox?.close());
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) lightbox.close();
  });

  // Sticky CTA on mobile (show after scrolling past hero)
  const stickyCta = document.getElementById('stickyCta');
  const hero = document.getElementById('hero');
  if (stickyCta && hero) {
    const stickyObserver = new IntersectionObserver(
      ([entry]) => {
        stickyCta.classList.toggle('visible', !entry.isIntersecting);
      },
      { threshold: 0 }
    );
    stickyObserver.observe(hero);
  }
</script>
