---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
// og:image cần URL tuyệt đối; Astro.site do CI truyền qua --site khi deploy
const ogImage = Astro.site
  ? new URL(`${base}images/og-banner.jpg`, Astro.site).href
  : `${base}images/og-banner.jpg`;
---
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:locale" content="vi_VN" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:alt" content="Thác Bản Giốc, Cao Bằng — Sen's Homestay" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="icon" type="image/svg+xml" href="favicon.svg" />
  <!-- Fonts (theo DESIGN.md web chính): Bricolage Grotesque (heading) +
       Hanken Grotesk (body) — cả hai đều có subset vietnamese.
       Source Serif 4 italic giữ cho pull-quote. -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700;12..96,800&family=Hanken+Grotesk:wght@400;500;600;700&family=Source+Serif+4:ital,opsz,wght@1,8..60,500&display=swap" />
</head>
<body>
  <slot />
</body>
</html>
